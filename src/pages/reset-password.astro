---
export const prerender = false;
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const uid = Astro.url.searchParams.get('uid');
const timestamp = Astro.url.searchParams.get('timestamp');
const hash = Astro.url.searchParams.get('hash');

if (!uid || !timestamp || !hash) {
  const lang = getLangFromUrl(Astro.url) as Lang;
  return Astro.redirect(`/${lang}/login`);
}

const lang = getLangFromUrl(Astro.url) as Lang;
return Astro.redirect(`/${lang}/reset-password?uid=${uid}&timestamp=${timestamp}&hash=${hash}`);
---
