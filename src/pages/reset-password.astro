---
export const prerender = false;
import type { Lang } from '@/i18n/ui';

const uid = Astro.url.searchParams.get('uid');
const timestamp = Astro.url.searchParams.get('timestamp');
const hash = Astro.url.searchParams.get('hash');

if (!uid || !timestamp || !hash) {
  const cookie = Astro.request.headers.get('cookie') || '';
  const match = cookie.match(/mf-lang=([^;]+)/);
  const lang = match?.[1] === 'en' ? 'en' : 'es';
  return Astro.redirect(`/${lang}/login`);
}

function detectLang(acceptLanguage: string, cookie: string): Lang {
  const match = cookie.match(/mf-lang=([^;]+)/);
  if (match?.[1] === 'en' || match?.[1] === 'es') return match[1] as Lang;
  for (const entry of acceptLanguage.split(',')) {
    const [tag] = entry.trim().split(';q=');
    const code = tag.split('-')[0].toLowerCase();
    if (code === 'en') return 'en';
    if (code === 'es') return 'es';
  }
  return 'es';
}

const cookie = Astro.request.headers.get('cookie') || '';
const acceptLanguage = Astro.request.headers.get('accept-language') || '';
const lang = detectLang(acceptLanguage, cookie);
return Astro.redirect(`/${lang}/reset-password?uid=${encodeURIComponent(uid)}&timestamp=${encodeURIComponent(timestamp)}&hash=${encodeURIComponent(hash)}`);
---
