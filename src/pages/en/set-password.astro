---
export const prerender = false;

import AuthLayout from '@/layouts/AuthLayout.astro';
import HeroPanel from '@/components/auth/HeroPanel.astro';
import SetPasswordForm from '@/components/auth/SetPasswordForm';

const uid = Astro.url.searchParams.get('uid');
const timestamp = Astro.url.searchParams.get('timestamp');
const hash = Astro.url.searchParams.get('hash');

if (!uid || !timestamp || !hash) {
  return Astro.redirect('/en/login');
}
---
<AuthLayout title="Activate account" lang="en">
  <main class="auth-main">
    <HeroPanel />
    <section class="form-section">
      <div class="form-container">
        <SetPasswordForm
          lang="en"
          uid={uid}
          timestamp={timestamp}
          hash={hash}
          client:load
        />
      </div>
    </section>
  </main>
</AuthLayout>

<style>
  .auth-main { display: flex; height: 100vh; overflow: hidden; }
  .form-section { width: 100%; display: flex; flex-direction: column; background: white; overflow-y: auto; }
  @media (min-width: 1024px) { .form-section { width: 50%; } }
  .form-container { flex: 1; display: flex; align-items: center; justify-content: center; padding: 2.5rem 1.5rem; }
  @media (min-width: 640px) { .form-container { padding: 2.5rem 3rem; } }
  @media (min-width: 768px) { .form-container { padding: 2.5rem 6rem; } }
</style>
