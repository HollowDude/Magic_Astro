---
// src/pages/en/shop/[id].astro
import HomeLayout from '@/layouts/HomeLayout.astro';
import HomeHeader from '@/components/home/HomeHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import ProductDetail, { type ProductDetailData } from '@/components/shop/ProductDetail';
import ProductCard, { type ProductCardData } from '@/components/shop/ProductCard';
import { getProductById, getRelatedProducts } from '@/services/drupal/drupal.product';
import { getProductThumbnail, getVariationGallery } from '@/types/commerce';
import { useTranslations } from '@/i18n/utils';
import Footer from '@/components/ui/Footer.astro';

const lang = 'en' as const;
const t = useTranslations(lang);
const DRUPAL_BASE_URL = import.meta.env.DRUPAL_BASE_URL as string;

const { id } = Astro.params;
if (!id) return Astro.redirect('/en/');

const product = await getProductById(id, lang);
if (!product) return Astro.redirect('/en/');

const variation = product.variations?.[0];
const allImages = variation ? getVariationGallery(variation, DRUPAL_BASE_URL) : [];

const productData: ProductDetailData = {
  id: product.id,
  title: product.title,
  price: variation?.price?.formatted ?? '',
  description: product.body?.processed ?? '',
  images: allImages,
  badge: variation?.field_tipo
    ? t(`shop.filters.type.${variation.field_tipo}` as Parameters<typeof t>[0])
    : null,
  tipo: variation?.field_tipo ?? null,
  colorName: variation?.field_color_de_la_flor?.name ?? null,
  colorHex: variation?.field_color_de_la_flor?.field_color_hex ?? null,
  category: (product as any).field_categoria?.name ?? null,
};

const rawRelated = await getRelatedProducts(product, lang, 4);
const relatedProducts: ProductCardData[] = rawRelated.map(p => {
  const v = p.variations?.[0];
  return {
    id: p.id,
    title: p.title,
    price: v?.price?.formatted ?? '',
    priceNumber: parseFloat(v?.price?.number ?? '0'),
    thumbnail: getProductThumbnail(p, DRUPAL_BASE_URL),
    badge: null,
    tipo: v?.field_tipo ?? null,
    colorName: v?.field_color_de_la_flor?.name ?? null,
    colorHex: v?.field_color_de_la_flor?.field_color_hex ?? null,
    category: (p as any).field_categoria?.name ?? null,
  };
});
---

<HomeLayout title={product.title}>
  <div class="flex flex-col min-h-screen">
    <HomeHeader />

    <main class="flex-1 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12 lg:py-20">
      
      <Breadcrumb crumbs={[
        { label: t('nav.home'), href: '/en' },
        { label: t('shop.title'), href: '/en/shop' },
        { label: product.title },
      ]} />

      <section class="mt-8">
        <ProductDetail product={productData} lang={lang} client:load />
      </section>

      <div class="h-px bg-border my-16 lg:my-24" role="separator"></div>

      {relatedProducts.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-8">
            <h2 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-semibold text-headline tracking-tight">
              {t('product.related.title')}
            </h2>
            <a 
              href="/en/shop" 
              class="group flex items-center gap-1 font-body text-sm font-bold text-primary no-underline hover:underline"
            >
              {t('product.related.see_all')}
              <span class="material-symbols-outlined !text-base transition-transform group-hover:translate-x-1">
                arrow_forward
              </span>
            </a>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 lg:gap-6">
            {relatedProducts.map(p => (
              <ProductCard
                product={p}
                lang={lang}
                href={`/en/shop/${p.id}`}
                client:visible
              />
            ))}
          </div>
        </section>
      )}
    </main>

    <Footer lang="en" />
  </div>
</HomeLayout>