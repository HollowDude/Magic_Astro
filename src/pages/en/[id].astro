---
export const prerender = false;

import ProductDetailContent from '@/components/pages/ProductDetailContent.astro';
import { getProductDetailPageData } from '@/services/nodehive/nodehive.product';

const lang = 'en' as const;
const { id } = Astro.params;
const selectedVariationId = Astro.url.searchParams.get('var');
const UUID_RE = /^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;
if (!id || !UUID_RE.test(id)) return Astro.redirect('/en/');

const data = await getProductDetailPageData(id, lang);
if (!data) return Astro.redirect('/en/');
---
<ProductDetailContent lang={lang} selectedVariationId={selectedVariationId} {...data} />