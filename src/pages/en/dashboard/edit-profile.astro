---
export const prerender = false;

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import EditProfileForm from '@/components/dashboard/EditProfileForm';
import { getSession } from '@/services/session.service';
import { getUserProfile } from '@/services/nodehive/nodehive.user';
import { nodehiveFetch } from '@/services/nodehive/nodehive.client';
import { existsSync } from 'node:fs';
import { readdirSync } from 'node:fs';
import path from 'node:path';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/en/login?redirect=/en/dashboard/edit-profile');

const lang = 'en' as const;
const profile = await getUserProfile(session.uid, lang, session.accessToken);
const userName = session.name ?? profile?.username ?? '';
const userMail = session.mail ?? profile?.mail ?? '';

const userRes = await nodehiveFetch<Record<string, unknown>>(
  `/jsonapi/user/user?filter[drupal_internal__uid]=${session.uid}&page[limit]=1`,
  { headers: { 'Content-Type': 'application/vnd.api+json', Accept: 'application/vnd.api+json' } }
);
const userUuid = (userRes.data as any)?.data?.[0]?.id ?? '';

// Check for profile picture: local upload first, then Drupal user_picture
let userPicture: string | null = null;
const uploadsDir = path.resolve(process.cwd(), 'data/uploads/profiles');
try {
  if (existsSync(uploadsDir)) {
    const files = readdirSync(uploadsDir);
    const match = files.find(f => f.startsWith(`${session.uid}.`));
    if (match) userPicture = `/api/files/profiles/${match}`;
  }
} catch { /* ignore */ }

if (!userPicture && session.accessToken) {
  try {
    const restRes = await nodehiveFetch<Record<string, unknown>>(
      `/user/${session.uid}?_format=json`,
      {
        headers: { Accept: 'application/json' },
        lang,
        bearerToken: session.accessToken,
      },
    );
    if (restRes.status === 200) {
      const restData = restRes.data as Record<string, any>;
      const pictureUrl = restData?.user_picture?.[0]?.url;
      if (pictureUrl) {
        userPicture = `/api/files/drupal-proxy?url=${encodeURIComponent(pictureUrl)}`;
      }
    }
  } catch { /* ignore */ }
}
---

<DashboardLayout title="Edit Profile — Maggy Flowers" lang={lang} activeSection="account">
  <EditProfileForm
    lang={lang}
    initialName={userName}
    initialMail={userMail}
    initialPicture={userPicture}
    userUuid={userUuid}
    client:load
  />
</DashboardLayout>
