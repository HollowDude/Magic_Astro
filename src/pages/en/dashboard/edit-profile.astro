---
export const prerender = false;

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { getSession } from '@/services/session.service';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/en/login?redirect=/en/dashboard/edit-profile');

const lang = 'en' as const;
---

<DashboardLayout title="Edit Profile — Maggy Flowers" lang={lang} activeSection="account">
  <div class="space-y-6">
    <nav class="flex items-center gap-2 text-xs text-body-color mb-2">
      <a href="/en/dashboard" class="hover:text-primary transition-colors">My Account</a>
      <span class="material-symbols-outlined text-[14px] leading-none">chevron_right</span>
      <span class="text-headline font-semibold">Edit Profile</span>
    </nav>

    <div class="bg-white rounded-xl border border-border shadow-sm p-8 text-center">
      <span class="material-symbols-outlined text-5xl text-muted opacity-30 mb-3 block">construction</span>
      <h1 class="font-heading text-xl text-headline mb-2">Feature in development</h1>
      <p class="text-body-color mb-6">Profile editing will be available soon.</p>
      <a href="/en/dashboard" class="btn-primary inline-flex">Back to my account</a>
    </div>
  </div>
</DashboardLayout>
