---
export const prerender = false;

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { getSession } from '@/services/session.service';
import { getUserProfile, getUserOrders, getUserAddresses } from '@/services/nodehive/nodehive.user';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/en/login?redirect=/en/dashboard');

const lang = 'en' as const;

const [profile, orders, addresses] = await Promise.all([
  getUserProfile(session.uid, lang),
  getUserOrders(session.uid, lang, 3, session.accessToken),
  getUserAddresses(session.uid, lang, session.accessToken),
]);

const displayName = session.name || profile?.displayName;
const mail = session.mail || profile?.mail || '';
const phone = profile?.phone || null;

const defaultAddress = addresses.find(a => a.isDefault) ?? addresses[0] ?? null;

const stateMeta: Record<string, { icon: string; bg: string; text: string }> = {
  placed:      { icon: 'local_florist',  bg: '#fffbeb', text: '#92400e' },
  fulfillment: { icon: 'local_shipping', bg: '#eff6ff', text: '#1e40af' },
  completed:   { icon: 'check_circle',   bg: 'var(--sage-light)', text: 'var(--sage)' },
  canceled:    { icon: 'cancel',         bg: '#fef2f2', text: '#dc2626' },
  draft:       { icon: 'edit_note',      bg: 'var(--blush)', text: 'var(--muted)' },
  validation:  { icon: 'pending',        bg: '#fffbeb', text: '#92400e' },
};
---

<DashboardLayout title="My Account" lang="en" activeSection="account">

  <div class="mb-8">
    <h1 class="text-2xl font-heading font-semibold text-headline tracking-tight">My Profile</h1>
    <p class="text-sm text-body-color mt-1">Manage your personal information and view your activity.</p>
  </div>

  <section class="bg-white rounded-xl border border-border shadow-sm p-6 mb-5">
    <div class="flex items-start sm:items-center justify-between gap-3 mb-5">
      <h2 class="text-base font-bold text-headline">Personal Information</h2>
      <a
        href="/en/dashboard/edit-profile"
        class="inline-flex items-center gap-1.5 text-xs font-bold text-primary bg-[var(--primary-alpha-7)] hover:bg-[var(--primary-alpha-12)] px-3 py-1.5 rounded-lg transition-colors shrink-0"
      >
        <span class="material-symbols-outlined text-[15px] leading-none">edit</span>
        Edit Profile
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-y-4 gap-x-6">
      <div>
        <p class="text-[11px] font-bold text-body-color uppercase tracking-widest mb-1">Full Name</p>
        <p class="text-sm font-semibold text-headline">
          {displayName || <span class="text-body-color italic">Not registered</span>}
        </p>
      </div>
      <div>
        <p class="text-[11px] font-bold text-body-color uppercase tracking-widest mb-1">Email</p>
        <p class="text-sm font-semibold text-headline break-all">
          {mail || <span class="text-body-color italic">Not available</span>}
        </p>
      </div>
      {phone && (
        <div>
          <p class="text-[11px] font-bold text-body-color uppercase tracking-widest mb-1">Phone</p>
          <p class="text-sm font-semibold text-headline">{phone}</p>
        </div>
      )}
    </div>
  </section>

  <section class="bg-white rounded-xl border border-border shadow-sm p-6 mb-5">
    <div class="flex items-start sm:items-center justify-between gap-3 mb-5">
      <h2 class="text-base font-bold text-headline">Primary Address</h2>
      <a
        href="/en/dashboard/addresses"
        class="inline-flex items-center gap-1.5 text-xs font-bold text-primary hover:underline shrink-0"
      >
        Manage addresses
        <span class="material-symbols-outlined text-[15px] leading-none">arrow_forward</span>
      </a>
    </div>

    {defaultAddress ? (
      <div class="flex flex-col sm:flex-row gap-6">
        <div class="flex-1">
          <p class="text-[11px] font-bold text-body-color uppercase tracking-widest mb-2">
            <span class="material-symbols-outlined text-[13px] text-primary leading-none align-middle mr-0.5">location_on</span>
            Shipping Address
          </p>
          <div class="text-sm text-headline leading-relaxed">
            {(defaultAddress.firstName || defaultAddress.lastName) && (
              <p class="font-semibold">{defaultAddress.firstName} {defaultAddress.lastName}</p>
            )}
            {defaultAddress.addressLine1 && <p>{defaultAddress.addressLine1}</p>}
            {defaultAddress.addressLine2 && <p>{defaultAddress.addressLine2}</p>}
            {(defaultAddress.city || defaultAddress.state) && (
              <p>{defaultAddress.city}{defaultAddress.state ? `, ${defaultAddress.state}` : ''}{defaultAddress.postalCode ? ` ${defaultAddress.postalCode}` : ''}</p>
            )}
            {defaultAddress.countryCode && <p>{defaultAddress.countryCode}</p>}
          </div>
        </div>
        <div class="sm:text-right">
          <a href="/en/dashboard/addresses" class="text-xs font-bold text-primary hover:underline">Edit address</a>
        </div>
      </div>
    ) : (
      <div class="text-center py-6">
        <span class="material-symbols-outlined text-[2rem] text-muted opacity-30">location_off</span>
        <p class="text-sm text-body-color mt-2 mb-4">No addresses saved yet.</p>
        <a href="/en/dashboard/addresses" class="text-sm font-bold text-primary hover:underline">Add address</a>
      </div>
    )}
  </section>

  <section class="bg-white rounded-xl border border-border shadow-sm p-6">
    <div class="flex items-start sm:items-center justify-between gap-3 mb-5">
      <h2 class="text-base font-bold text-headline">Recent Orders</h2>
      <a
        href="/en/dashboard/orders"
        class="inline-flex items-center gap-1.5 text-xs font-bold text-primary hover:underline shrink-0"
      >
        View all
        <span class="material-symbols-outlined text-[15px] leading-none">arrow_forward</span>
      </a>
    </div>

    {orders.length === 0 ? (
      <div class="text-center py-10">
        <svg class="index-empty-svg" viewBox="0 0 120 80" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="30" cy="50" r="18" fill="var(--blush)" />
          <circle cx="60" cy="30" r="14" fill="var(--sage-light)" />
          <circle cx="90" cy="55" r="16" fill="var(--blush)" />
          <path d="M30 35a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3h-2a3 3 0 0 1-3-3v-8a3 3 0 0 1 3-3h2z" fill="var(--primary)" opacity="0.3" />
          <path d="M60 18a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3h-2a3 3 0 0 1-3-3v-8a3 3 0 0 1 3-3h2z" fill="var(--sage)" opacity="0.3" />
          <path d="M90 41a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3h-2a3 3 0 0 1-3-3v-8a3 3 0 0 1 3-3h2z" fill="var(--primary)" opacity="0.3" />
        </svg>
        <p class="text-sm text-body-color mt-2 mb-4">You have no orders yet.</p>
        <a href="/en/shop" class="text-sm font-bold text-primary hover:underline">Browse the shop</a>
      </div>
    ) : (
      <div class="divide-y divide-border">
        {orders.map((order) => {
          const meta = stateMeta[order.state] ?? stateMeta.placed;
          const isPickup = order.shippingMethod === 'pickup';
          const fulfillmentLabel = isPickup ? 'Ready for pickup' : 'Shipped';
          const effectiveStateLabel = order.state === 'fulfillment' ? fulfillmentLabel : order.stateLabel;
          return (
            <a
              href={`/en/dashboard/orders/${order.id}`}
              class="index-order-row group"
            >
              <div class="ior-left">
                <span class="ior-icon" style={{ color: meta.text }}>
                  <span class="material-symbols-outlined">{meta.icon}</span>
                </span>
                <div>
                  <div class="ior-title-row">
                    <span class="ior-number">#{order.orderNumber}</span>
                    <span class="ior-badge" style={{ background: meta.bg, color: meta.text }}>{effectiveStateLabel}</span>
                  </div>
                  <p class="ior-meta">{order.placedDateFormatted}{order.itemCount > 0 ? ` · ${order.itemCount} item${order.itemCount !== 1 ? 's' : ''}` : ''}</p>
                </div>
              </div>
              <div class="ior-right">
                <span class="ior-price">{order.totalFormatted}</span>
                <span class="material-symbols-outlined ior-chevron">chevron_right</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>

</DashboardLayout>

<style>
  .index-empty-svg {
    width: 100px;
    height: 70px;
    margin: 0 auto 1rem;
    display: block;
  }
  .index-order-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.75rem 0.5rem;
    border-radius: 0.5rem;
    transition: background 0.2s;
    text-decoration: none;
  }
  .index-order-row:hover {
    background: var(--primary-alpha-4);
  }
  .ior-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }
  .ior-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ior-icon .material-symbols-outlined {
    font-size: 1.25rem;
  }
  .ior-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .ior-number {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--headline);
  }
  .ior-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 700;
  }
  .ior-meta {
    font-size: 0.75rem;
    color: var(--body-color);
    margin-top: 0.125rem;
  }
  .ior-right {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    flex-shrink: 0;
  }
  .ior-price {
    font-family: var(--font-heading);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--primary);
  }
  .ior-chevron {
    font-size: 1.125rem !important;
    color: var(--body-color);
    opacity: 0.5;
    transition: opacity 0.2s;
  }
  .index-order-row:hover .ior-chevron {
    opacity: 1;
    color: var(--primary);
  }
</style>
