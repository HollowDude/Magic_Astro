---
export const prerender = false;

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { getSession } from '@/services/session.service';
import { getUserOrders } from '@/services/nodehive/nodehive.user';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/en/login?redirect=/en/dashboard/orders');

const lang = 'en' as const;
const orders = await getUserOrders(session.uid, lang, 20, session.accessToken);

interface CheckoutData {
  currentStep?: number;
  stepsCompleted?: number[];
  cancelledAtStep?: number;
  [key: string]: any;
}

const stateStyles: Record<string, string> = {
  placed:      'bg-amber-100 text-amber-700',
  fulfillment: 'bg-blue-100 text-blue-700',
  completed:   'bg-emerald-100 text-emerald-700',
  canceled:    'bg-red-100 text-red-600',
  draft:       'bg-gray-100 text-gray-600',
  validation:  'bg-yellow-100 text-yellow-700',
};
---

<DashboardLayout title="My Orders — Maggy Flowers" lang="en" activeSection="orders">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="font-heading text-2xl text-headline font-semibold">My Orders</h1>
      {orders.length > 0 && (
        <span class="text-xs text-body-color bg-blush px-3 py-1 rounded-full font-medium">{orders.length} order{orders.length !== 1 ? 's' : ''}</span>
      )}
    </div>

    {orders.length === 0 ? (
      <div class="bg-white rounded-xl border border-border shadow-sm p-12 text-center">
        <span class="material-symbols-outlined text-5xl text-muted opacity-30 mb-3 block">inbox</span>
        <p class="font-semibold text-headline mb-1">You have no orders yet</p>
        <p class="text-sm text-body-color mb-6">Once you place your first order, it will appear here.</p>
        <a href="/en/shop" class="btn-primary inline-flex">Browse products</a>
      </div>
    ) : (
      <div class="space-y-4">
        {orders.map((order) => {
          const style = stateStyles[order.state] ?? stateStyles.placed;
          return (
            <a
              href={`/en/dashboard/orders/${order.id}`}
              class="bg-white rounded-xl border border-border shadow-sm overflow-hidden hover:border-primary/30 transition-colors block group"
            >
              <div class="flex items-center justify-between px-5 py-3 bg-blush/50 border-b border-border">
                <div>
                  <span class="text-xs text-muted font-medium uppercase tracking-wider">Order</span>
                  <p class="font-semibold text-text-main">{order.state === 'draft' && order.orderNumber === '—' ? 'No number' : `#${order.orderNumber}`}</p>
                </div>
                <div class="text-right flex items-center gap-3">
                  <span class={`inline-flex items-center px-3 py-1 rounded-full text-xs font-bold ${style}`}>{order.stateLabel}</span>
                  <span class="material-symbols-outlined text-[18px] text-body-color group-hover:text-primary transition-colors">chevron_right</span>
                </div>
              </div>
              <div class="px-5 py-4">
                {order.items.map((item, i) => (
                  <div class={`flex items-center justify-between py-2 ${i < order.items.length - 1 ? 'border-b border-border/50' : ''}`}>
                    <div>
                      <p class="font-medium text-text-main text-sm">{item.title}</p>
                      <p class="text-xs text-body-color">Qty: {item.quantity}</p>
                    </div>
                    <span class="text-sm font-medium text-text-main">{item.unitPriceFormatted}</span>
                  </div>
                ))}
                <div class="flex items-center justify-between pt-3 mt-2 border-t border-border">
                  <span class="text-xs text-muted">{order.placedDateFormatted}</span>
                  <div class="flex items-center gap-2">
                    {order.state === 'draft' && order.checkoutStarted && (
                      <a href={`/en/checkout`} class="text-xs font-bold text-primary hover:underline">Continue</a>
                    )}
                    {order.state === 'placed' && order.currentCheckoutStep !== null && (
                      <a href={`/en/checkout?resume=${order.id}`} class="text-xs font-bold text-primary hover:underline">Continue Checkout</a>
                    )}
                    <span class="font-bold text-headline">{order.totalFormatted}</span>
                  </div>
                </div>

                {(order.checkoutStarted && order.state === 'draft') || (order.state === 'placed' && order.currentCheckoutStep !== null) ? (
                  <div class="mt-3">
                    <div class="text-xs text-muted mb-1">
                      Step {(order.currentCheckoutStep ?? 0) + 1} of 4
                    </div>
                    <div class="flex gap-1">
                      {[0,1,2,3].map(i => (
                        <div class={`h-1 flex-1 rounded-full ${i <= (order.currentCheckoutStep ?? 0) ? 'bg-primary' : 'bg-border'}`} />
                      ))}
                    </div>
                  </div>
                ) : null}

                {order.state === 'canceled' && order.cancelledAtStep !== null && order.cancelledAtStep !== undefined && (
                  <div class="mt-2 text-xs text-muted">
                    Canceled at step {order.cancelledAtStep + 1}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</DashboardLayout>
