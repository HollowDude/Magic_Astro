---
export const prerender = false;
import HomeLayout from '@/layouts/HomeLayout.astro';
import { getSession } from '@/services/session.service';
import { getFooterContactData } from '@/services/nodehive/nodehive.footer';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/en/login');

const orderNumber = Astro.url.searchParams.get('order') ?? '';
const drupalOrderId = Astro.url.searchParams.get('orderId') ?? '';
const amount = Astro.url.searchParams.get('amount') ?? '';
const lang = 'en';

const contactData = await getFooterContactData(lang);
const zellePhone = contactData?.zelle ?? import.meta.env.ZELLE_RECIPIENT_PHONE;
const zelleName = contactData?.title ?? import.meta.env.ZELLE_RECIPIENT_NAME;
---

<HomeLayout title="Complete your payment — Maggy Flowers" lang={lang}>
  <div class="zpend-page">

    <div class="zpend-hero">
      <div class="zpend-icon-wrap">
        <span class="material-symbols-outlined zpend-icon">schedule</span>
      </div>
      <h1 class="zpend-title">Order received!</h1>
      <p class="zpend-subtitle">Just complete the Zelle transfer to confirm your order.</p>
      {orderNumber && (
        <div class="zpend-order-badge">
          <span class="zpend-order-label">Order number</span>
          <span class="zpend-order-number">{orderNumber}</span>
        </div>
      )}
    </div>

    <div class="zpend-instructions-card">
      <h2 class="zpend-card-title">
        <span class="zpend-zelle-dot">Zelle</span>
        Payment instructions
      </h2>

      <div class="zpend-steps">
        <div class="zpend-step">
          <span class="zpend-step-num">1</span>
          <div>
            <p class="zpend-step-title">Open your banking app</p>
            <p class="zpend-step-desc">Go to the Zelle section in your bank.</p>
          </div>
        </div>
        <div class="zpend-step">
          <span class="zpend-step-num">2</span>
          <div>
            <p class="zpend-step-title">Send exactly</p>
            <div class="zpend-amount-box">
              <span class="zpend-amount">{amount}</span>
              <span class="zpend-amount-label">USD</span>
            </div>
          </div>
        </div>
        <div class="zpend-step">
          <span class="zpend-step-num">3</span>
          <div>
            <p class="zpend-step-title">To the number / email</p>
            <div class="zpend-recipient-box">
              <span class="zpend-recipient-phone">{zellePhone}</span>
              <span class="zpend-recipient-name">{zelleName}</span>
              <button class="zpend-copy-btn" onclick={`navigator.clipboard.writeText('${zellePhone}')`}>
                <span class="material-symbols-outlined" style="font-size:1rem">content_copy</span>
                Copy
              </button>
            </div>
          </div>
        </div>
        <div class="zpend-step">
          <span class="zpend-step-num">4</span>
          <div>
            <p class="zpend-step-title">Include in the memo</p>
            <div class="zpend-ref-box">
              <code class="zpend-ref">{orderNumber}</code>
              <button class="zpend-copy-btn" onclick={`navigator.clipboard.writeText('${orderNumber}')`}>
                <span class="material-symbols-outlined" style="font-size:1rem">content_copy</span>
                Copy
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="zpend-note">
        <span class="material-symbols-outlined" style="font-size:1rem;color:var(--sage)">verified_user</span>
        You'll receive a confirmation email once we verify your payment (usually within 2 hours during business hours).
      </div>
    </div>

    <div class="zpend-actions">
      <a href={`/${lang}/dashboard/orders`} class="btn-primary zpend-btn">
        <span class="material-symbols-outlined" style="font-size:1.125rem">receipt_long</span>
        View my order status
      </a>
      <a href={`/${lang}/shop`} class="zpend-link-shop">
        Continue shopping
      </a>
    </div>

  </div>
</HomeLayout>

<style>
  .zpend-page {
    max-width: 36rem;
    margin: 0 auto;
    padding: 2.5rem 1rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .zpend-hero { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
  .zpend-icon-wrap {
    width: 5rem; height: 5rem; border-radius: 50%;
    background: #fffbeb;
    display: flex; align-items: center; justify-content: center;
  }
  .zpend-icon { font-size: 2.75rem !important; color: #f59e0b; }
  .zpend-title { font-family: var(--font-heading); font-size: 1.75rem; font-weight: 600; color: var(--headline); }
  .zpend-subtitle { font-size: 0.9375rem; color: var(--text-muted); max-width: 28rem; line-height: 1.5; }
  .zpend-order-badge {
    display: flex; flex-direction: column; align-items: center; gap: 0.25rem;
    background: var(--blush);
    border: 1.5px solid color-mix(in srgb, var(--primary) 20%, transparent);
    border-radius: 1rem; padding: 0.875rem 2rem;
  }
  .zpend-order-label { font-size: 0.6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); }
  .zpend-order-number { font-family: var(--font-heading); font-size: 1.375rem; font-weight: 600; color: var(--headline); }

  .zpend-instructions-card {
    background: white; border: 1.5px solid var(--border);
    border-radius: 1rem; padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(109,81,87,0.06);
  }
  .zpend-card-title {
    display: flex; align-items: center; gap: 0.5rem;
    font-family: var(--font-body); font-size: 1rem; font-weight: 700;
    color: var(--headline); margin-bottom: 1.5rem;
  }
  .zpend-zelle-dot {
    background: #6d1ed4; color: white;
    font-size: 0.75rem; font-weight: 700;
    padding: 0.125rem 0.625rem; border-radius: 0.375rem;
    letter-spacing: 0.02em;
  }

  .zpend-steps { display: flex; flex-direction: column; gap: 1.25rem; }
  .zpend-step { display: flex; align-items: flex-start; gap: 1rem; }
  .zpend-step-num {
    width: 1.75rem; height: 1.75rem; border-radius: 50%;
    background: var(--blush); color: var(--primary);
    font-size: 0.8125rem; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; margin-top: 0.125rem;
  }
  .zpend-step-title { font-size: 0.875rem; font-weight: 700; color: var(--headline); margin-bottom: 0.375rem; }
  .zpend-step-desc { font-size: 0.8125rem; color: var(--text-muted); }

  .zpend-amount-box {
    display: inline-flex; align-items: baseline; gap: 0.375rem;
    background: color-mix(in srgb, var(--primary) 6%, transparent);
    border: 1.5px solid color-mix(in srgb, var(--primary) 20%, transparent);
    border-radius: 0.625rem; padding: 0.625rem 1rem;
  }
  .zpend-amount { font-family: var(--font-heading); font-size: 1.75rem; font-weight: 600; color: var(--primary); }
  .zpend-amount-label { font-size: 0.875rem; color: var(--text-muted); font-weight: 600; }

  .zpend-recipient-box {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
    background: var(--blush); border-radius: 0.625rem; padding: 0.625rem 0.875rem;
  }
  .zpend-recipient-phone { font-family: var(--font-heading); font-size: 1.125rem; font-weight: 600; color: var(--headline); }
  .zpend-recipient-name { font-size: 0.8125rem; color: var(--text-muted); flex: 1; }

  .zpend-ref-box { display: flex; align-items: center; gap: 0.5rem; }
  .zpend-ref {
    font-family: monospace; font-size: 1rem; font-weight: 700;
    background: var(--blush); color: var(--headline);
    padding: 0.375rem 0.75rem; border-radius: 0.5rem;
  }

  .zpend-copy-btn {
    display: inline-flex; align-items: center; gap: 0.25rem;
    font-size: 0.75rem; font-weight: 600; color: var(--primary);
    background: none; border: none; cursor: pointer; font-family: inherit;
    padding: 0.25rem 0.5rem; border-radius: 0.375rem; transition: background 0.15s;
  }
  .zpend-copy-btn:hover { background: color-mix(in srgb, var(--primary) 8%, transparent); }

  .zpend-note {
    display: flex; align-items: flex-start; gap: 0.5rem;
    background: color-mix(in srgb, var(--sage) 8%, transparent);
    color: var(--sage);
    font-size: 0.8125rem; line-height: 1.5; font-weight: 500;
    padding: 0.875rem 1rem; border-radius: 0.625rem; margin-top: 1.5rem;
  }

  .zpend-actions { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; }
  .zpend-btn { width: 100%; height: 3.125rem; font-size: 0.9375rem; font-weight: 700; border-radius: 0.75rem; gap: 0.5rem; }
  .zpend-link-shop { font-size: 0.875rem; font-weight: 600; color: var(--text-muted); text-decoration: none; transition: color 0.15s; }
  .zpend-link-shop:hover { color: var(--primary); }
</style>
