---
import HomeLayout from '@/layouts/HomeLayout.astro';
import { getSession } from '@/services/session.service';

const session = await getSession(Astro.cookies);
if (!session) return Astro.redirect('/en/login');
---

<HomeLayout title="Dashboard">
  <main style="flex:1; display:flex; align-items:center; justify-content:center; padding:2rem;">
    <div class="card" style="padding:3rem; text-align:center; max-width:28rem; margin:auto;">
      <div style="width:5rem; height:5rem; background:color-mix(in srgb, var(--primary) 12%, transparent); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
        <span class="material-symbols-outlined" style="font-size:2.5rem; color:var(--primary);">local_florist</span>
      </div>
      <h1 style="font-size:1.625rem; font-weight:800; letter-spacing:-0.03em; margin-bottom:0.5rem; color:var(--headline);">
        Hi, {session.name}!
      </h1>
      <p style="color:var(--text-muted); font-size:0.9375rem; line-height:1.6;">
        You've signed in successfully. Your learning dashboard is coming soon.
      </p>
      <div style="display:inline-flex; align-items:center; gap:0.375rem; margin-top:1.5rem; padding:0.375rem 0.875rem; background:var(--bg); border:1px solid var(--border); border-radius:99px; font-size:0.8125rem; color:var(--text-muted); font-weight:500;">
        <span class="material-symbols-outlined" style="font-size:0.875rem;">person</span>
        UID: {session.uid}
      </div>
      <div style="margin-top:2rem;">
        <button
          id="logout-btn"
          class="btn-primary"
          style="font-size:0.9375rem;"
        >
          <span class="material-symbols-outlined" style="font-size:1.125rem;">logout</span>
          Sign out
        </button>
      </div>
    </div>
  </main>

  <script>
    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/en/';
    });
  </script>
</HomeLayout>
