---
// src/pages/en/shop.astro
import HomeLayout from '@/layouts/HomeLayout.astro';
import HomeHeader from '@/components/home/HomeHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import ShopClient from '@/components/shop/ShopClient';
import { getFloresProducts } from '@/services/drupal/drupal.commerce';
import { getCategoriasDeFlores } from '@/services/drupal/drupal.taxonomy';
import { getProductThumbnail } from '@/types/commerce';
import { useTranslations } from '@/i18n/utils';
import type { ProductCardData } from '@/components/shop/ProductCard';
import type { ShopCategory } from '@/components/shop/ShopClient';

const lang = 'en' as const;
const t    = useTranslations(lang);
const DRUPAL_BASE_URL = import.meta.env.DRUPAL_BASE_URL as string;

const catParam = Astro.url.searchParams.get('cat') ?? '';

const [rawProducts, rawCategories] = await Promise.all([
  getFloresProducts(lang),
  getCategoriasDeFlores(10, lang),
]);

const products: ProductCardData[] = rawProducts.map(p => {
  const v = p.variations?.[0];
  return {
    id:          p.id,
    title:       p.title,
    subtitle:    v?.field_color_de_la_flor?.name  ?? null,
    price:       v?.price?.formatted              ?? '',
    priceNumber: parseFloat(v?.price?.number      ?? '0'),
    thumbnail:   getProductThumbnail(p, DRUPAL_BASE_URL),
    badge:       null,
    tipo:        v?.field_tipo                    ?? null,
    colorName:   v?.field_color_de_la_flor?.name  ?? null,
    colorHex:    v?.field_color_de_la_flor?.field_color_hex ?? null,
  };
});

const categories: ShopCategory[] = rawCategories.map(c => ({
  id:   String(c.drupal_internal__tid),
  name: c.name,
  slug: c.name.toLowerCase().replace(/\s+/g, '-'),
}));
---

<HomeLayout title={t('shop.title')}>
  <div class="site-wrapper">
    <HomeHeader />

    <main class="shop-main">

      <div class="shop-hero">
        <Breadcrumb crumbs={[
          { label: t('nav.home'), href: '/en' },
          { label: t('shop.title') },
        ]} />

        <div class="shop-hero-inner">
          <div>
            <h1 class="shop-title">{t('shop.title')}</h1>
            <p class="shop-desc">{t('shop.description')}</p>
          </div>
        </div>
      </div>

      <ShopClient
        products={products}
        categories={categories}
        lang={lang}
        initialCat={catParam}
        client:load
      />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="material-symbols-outlined footer-icon">local_florist</span>
          <span class="footer-name">Maggy Flowers</span>
        </div>
        <p class="footer-copy">© {new Date().getFullYear()} Maggy Flowers. All rights reserved.</p>
        <nav class="footer-links">
          <a href="/en/shop">Shop</a>
          <a href="/en/courses">Courses</a>
          <a href="/en/about">About</a>
          <a href="/en/contact">Contact</a>
        </nav>
      </div>
    </footer>
  </div>
</HomeLayout>

<style>
  .site-wrapper { display: flex; flex-direction: column; min-height: 100vh; }

  .shop-main {
    flex: 1;
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1rem 5rem;
  }
  @media (min-width: 640px)  { .shop-main { padding-inline: 1.5rem; } }
  @media (min-width: 1024px) { .shop-main { padding-inline: 2rem; } }

  .shop-hero { margin-bottom: 2.5rem; }
  .shop-hero-inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.25rem;
  }
  .shop-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--headline);
    margin: 0 0 0.375rem;
    line-height: 1.1;
  }
  .shop-desc {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-muted);
    margin: 0;
    max-width: 36rem;
  }

  .site-footer { background: #211114; color: rgba(255 255 255 / 0.7); padding: 2.5rem 1rem; margin-top: auto; }
  .footer-inner { max-width: 80rem; margin: 0 auto; display: flex; flex-direction: column; align-items: center; gap: 1.25rem; text-align: center; }
  @media (min-width: 768px) { .footer-inner { flex-direction: row; justify-content: space-between; text-align: left; } }
  .footer-brand { display: flex; align-items: center; gap: 0.5rem; color: white; font-weight: 700; font-size: 1.125rem; }
  .footer-icon  { color: #eb4763; font-size: 1.5rem; }
  .footer-copy  { font-size: 0.8125rem; color: rgba(255 255 255 / 0.5); }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-size: 0.875rem; font-weight: 500; color: rgba(255 255 255 / 0.6); text-decoration: none; transition: color 0.2s; }
  .footer-links a:hover { color: #eb4763; }
</style>