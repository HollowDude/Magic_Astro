---
// Lógica de script idéntica (se mantiene igual)...
import HomeLayout from '@/layouts/HomeLayout.astro';
import HomeHeader from '@/components/home/HomeHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import ProductDetail from '@/components/shop/ProductDetail';
import ProductCard from '@/components/shop/ProductCard';
import { getProductById, getRelatedProducts } from '@/services/drupal/drupal.product';
import { getProductThumbnail, getVariationGallery } from '@/types/commerce';
import { useTranslations } from '@/i18n/utils';
import Footer from '@/components/ui/Footer.astro';

const lang = 'es' as const;
const t = useTranslations(lang);
const DRUPAL_BASE_URL = import.meta.env.DRUPAL_BASE_URL as string;

const { id } = Astro.params;
if (!id) return Astro.redirect('/shop');

const product = await getProductById(id, lang);
if (!product) return Astro.redirect('/shop');

const variation = product.variations?.[0];
const allImages = variation ? getVariationGallery(variation, DRUPAL_BASE_URL) : [];

const productData = {
  id: product.id,
  title: product.title,
  price: variation?.price?.formatted ?? '',
  description: product.body?.processed ?? '',
  images: allImages,
  badge: variation?.field_tipo ? t(`shop.filters.type.${variation.field_tipo}` as any) : null,
  tipo: variation?.field_tipo ?? null,
  colorName: variation?.field_color_de_la_flor?.name ?? null,
  colorHex: variation?.field_color_de_la_flor?.field_color_hex ?? null,
  category: (product as any).field_categoria?.name ?? null,
};

const rawRelated = await getRelatedProducts(product, lang, 4);
const relatedProducts = rawRelated.map(p => {
  const v = p.variations?.[0];
  return {
    id: p.id,
    title: p.title,
    price: v?.price?.formatted ?? '',
    priceNumber: parseFloat(v?.price?.number ?? '0'),
    thumbnail: getProductThumbnail(p, DRUPAL_BASE_URL),
    badge: null,
    tipo: v?.field_tipo ?? null,
    colorName: v?.field_color_de_la_flor?.name ?? null,
    colorHex: v?.field_color_de_la_flor?.field_color_hex ?? null,
    category: (p as any).field_categoria?.name ?? null,
  };
});
---

<HomeLayout title={product.title}>
  <div class="flex flex-col min-h-screen">
    <HomeHeader />

    <main class="main-container">
      <Breadcrumb crumbs={[
        { label: t('nav.home'), href: '/' },
        { label: t('shop.title'), href: '/shop' },
        { label: product.title },
      ]} />

      <div class="mt-8">
        <ProductDetail product={productData} lang={lang} client:load />
      </div>

      <hr class="section-divider" />

      {relatedProducts.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-8">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold text-headline tracking-tight">
              {t('product.related.title')}
            </h2>
            <a href="/shop" class="group flex items-center gap-1 font-body text-sm font-bold text-primary hover:underline">
              {t('product.related.see_all')}
              <span class="material-symbols-outlined text-base transition-transform group-hover:translate-x-1">
                arrow_forward
              </span>
            </a>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 lg:gap-6">
            {relatedProducts.map(p => (
              <ProductCard
                product={p}
                lang={lang}
                href={`/${p.id}`}
                client:visible
              />
            ))}
          </div>
        </section>
      )}
    </main>

    <Footer lang="es" />
  </div>
</HomeLayout>