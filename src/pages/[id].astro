---
import ProductDetailContent from '@/components/pages/ProductDetailContent.astro';
import { getProductDetailPageData } from '@/services/nodehive/nodehive.product';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang; // ← ya no es 'es' fijo
const { id } = Astro.params;
if (!id) return Astro.redirect(lang === 'en' ? '/en/' : '/shop');

const data = await getProductDetailPageData(id, lang);
if (!data) return Astro.redirect(lang === 'en' ? '/en/' : '/shop');
---
<ProductDetailContent lang={lang} {...data} />