---
// src/pages/shop/[id].astro
// Página de detalle de producto — Español (ruta: /shop/[uuid])

import HomeLayout from '@/layouts/HomeLayout.astro';
import HomeHeader from '@/components/home/HomeHeader.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import ProductDetail, { type ProductDetailData } from '@/components/shop/ProductDetail';
import ProductCard, { type ProductCardData } from '@/components/shop/ProductCard';
import { getProductById, getRelatedProducts } from '@/services/drupal/drupal.product';
import { getProductThumbnail, getVariationGallery } from '@/types/commerce';
import { useTranslations } from '@/i18n/utils';

const lang = 'es' as const;
const t    = useTranslations(lang);
const DRUPAL_BASE_URL = import.meta.env.DRUPAL_BASE_URL as string;

// ── Parámetros de ruta ─────────────────────────────────────────────────────
const { id } = Astro.params;
if (!id) return Astro.redirect('/shop');

// ── Fetch paralelo: producto + relacionados ────────────────────────────────
const product = await getProductById(id, lang);
if (!product) return Astro.redirect('/shop');

const variation = product.variations?.[0];
const allImages  = variation ? getVariationGallery(variation, DRUPAL_BASE_URL) : [];

// Normalizar al DTO del componente
const productData: ProductDetailData = {
  id:          product.id,
  title:       product.title,
  price:       variation?.price?.formatted ?? '',
  description: product.body?.processed    ?? '',
  images:      allImages,
  badge:       variation?.field_tipo
                 ? t(`shop.filters.type.${variation.field_tipo}` as Parameters<typeof t>[0])
                 : null,
  tipo:        variation?.field_tipo                            ?? null,
  colorName:   variation?.field_color_de_la_flor?.name         ?? null,
  colorHex:    variation?.field_color_de_la_flor?.field_color_hex ?? null,
  category:    (product as any).field_categoria?.name          ?? null,
};

// Relacionados
const rawRelated = await getRelatedProducts(product, lang, 4);
const relatedProducts: ProductCardData[] = rawRelated.map(p => {
  const v = p.variations?.[0];
  return {
    id:          p.id,
    title:       p.title,
    price:       v?.price?.formatted              ?? '',
    priceNumber: parseFloat(v?.price?.number      ?? '0'),
    thumbnail:   getProductThumbnail(p, DRUPAL_BASE_URL),
    badge:       null,
    tipo:        v?.field_tipo                    ?? null,
    colorName:   v?.field_color_de_la_flor?.name  ?? null,
    colorHex:    v?.field_color_de_la_flor?.field_color_hex ?? null,
    category:    (p as any).field_categoria?.name ?? null,
  };
});
---

<HomeLayout title={product.title}>
  <div class="site-wrapper">
    <HomeHeader />

    <main class="pd-main">

      <!-- Breadcrumb -->
      <Breadcrumb crumbs={[
        { label: t('nav.home'),   href: '/' },
        { label: t('shop.title'), href: '/shop' },
        { label: product.title },
      ]} />

      <!-- Sección de detalle (island React) -->
      <div class="pd-section">
        <ProductDetail product={productData} lang={lang} client:load />
      </div>

      <!-- Divisor -->
      <div class="pd-divider" role="separator"></div>

      <!-- Productos relacionados -->
      {relatedProducts.length > 0 && (
        <section class="pd-related">
          <div class="pd-related-header">
            <h2 class="pd-related-title">{t('product.related.title')}</h2>
            <a href="/" class="pd-related-link">
              {t('product.related.see_all')}
              <span class="material-symbols-outlined" style="font-size: 1rem; line-height: 1;">
                arrow_forward
              </span>
            </a>
          </div>

          <div class="pd-related-grid">
            {relatedProducts.map(p => (
              <ProductCard
                product={p}
                lang={lang}
                href={`/${p.id}`}
                client:visible
              />
            ))}
          </div>
        </section>
      )}

    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="material-symbols-outlined footer-icon">local_florist</span>
          <span class="footer-name">Maggy Flowers</span>
        </div>
        <p class="footer-copy">
          © {new Date().getFullYear()} Maggy Flowers. Todos los derechos reservados.
        </p>
        <nav class="footer-links">
          <a href="/shop">Tienda</a>
          <a href="/courses">Cursos</a>
          <a href="/about">Nosotros</a>
          <a href="/contact">Contacto</a>
        </nav>
      </div>
    </footer>
  </div>
</HomeLayout>

<style>
  .site-wrapper { display: flex; flex-direction: column; min-height: 100vh; }

  .pd-main {
    flex: 1;
    width: 100%;
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1rem 5rem;
  }
  @media (min-width: 640px)  { .pd-main { padding-inline: 1.5rem; } }
  @media (min-width: 1024px) { .pd-main { padding-inline: 2rem; } }

  /* Espaciado sobre el bloque de detalle */
  .pd-section { margin-top: 2rem; }

  /* Divisor */
  .pd-divider {
    height: 1px;
    background: var(--border);
    margin-block: 4rem;
  }

  /* Relacionados */
  .pd-related-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .pd-related-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--headline);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .pd-related-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--primary);
    text-decoration: none;
    transition: gap 0.2s;
  }
  .pd-related-link:hover { gap: 0.5rem; text-decoration: underline; }

  .pd-related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  @media (min-width: 768px)  { .pd-related-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .pd-related-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; } }

  /* Footer */
  .site-footer {
    background: #211114;
    color: rgba(255 255 255 / 0.7);
    padding: 2.5rem 1rem;
    margin-top: auto;
  }
  .footer-inner {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }
  @media (min-width: 768px) {
    .footer-inner { flex-direction: row; justify-content: space-between; text-align: left; }
  }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: white;
    font-weight: 700;
    font-size: 1.125rem;
  }
  .footer-icon  { color: #eb4763; font-size: 1.5rem; }
  .footer-copy  { font-size: 0.8125rem; color: rgba(255 255 255 / 0.5); }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255 255 255 / 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: #eb4763; }
</style>