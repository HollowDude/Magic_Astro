<script define:vars={{ orderId: id }}>
  const cancelBtn = document.getElementById('cancel-order-btn');
  const modal = document.getElementById('cancel-modal');
  const modalYes = document.getElementById('cancel-modal-yes');
  const modalNo = document.getElementById('cancel-modal-no');

  function showModal() {
    if (modal) modal.style.display = 'flex';
  }
  function hideModal() {
    if (modal) modal.style.display = 'none';
  }

  if (cancelBtn) {
    cancelBtn.addEventListener('click', showModal);
  }
  if (modalNo) {
    modalNo.addEventListener('click', hideModal);
  }
  if (modal) {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) hideModal();
    });
  }

  if (modalYes) {
    modalYes.addEventListener('click', async () => {
      modalYes.disabled = true;
      modalYes.textContent = 'Cancelando...';
      try {
        const res = await fetch('/api/checkout/cancel-order', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orderUuid: orderId }),
        });
        const data = await res.json();
        if (data.ok) {
          window.location.reload();
        } else {
          alert('Error: ' + (data.error ?? 'No se pudo cancelar'));
          modalYes.disabled = false;
          modalYes.textContent = 'Sí, cancelar';
          hideModal();
        }
      } catch {
        alert('Error de conexión');
        modalYes.disabled = false;
        modalYes.textContent = 'Sí, cancelar';
        hideModal();
      }
    });
  }
</script>
