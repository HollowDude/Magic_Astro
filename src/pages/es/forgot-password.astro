---
export const prerender = false;

import AuthLayout from '@/layouts/AuthLayout.astro';
import HeroPanel from '@/components/auth/HeroPanel.astro';
import ForgotPasswordForm from '@/components/auth/ForgotPasswordForm';
import { getSession } from '@/services/session.service';
import { getAuthPageData } from '@/services/nodehive/nodehive.paragraphs';
import type { Lang } from '@/i18n/ui';

const lang: Lang = 'es';
const session = await getSession(Astro.cookies);
if (session) return Astro.redirect('/es/dashboard', 302);

const pageData = await getAuthPageData('login', lang);
const hero = pageData?.heroPanel ?? null;
const formHeader = pageData?.formHeader ?? null;
---
<AuthLayout title="Recuperar Contraseña" lang="es" pageData={pageData}>
  <main class="auth-main">
    <HeroPanel
      title={hero?.title}
      description={hero?.description}
      fotoUrl={hero?.fotoUrl}
      paragraphId={hero?.paragraphId}
      paragraphInternalId={hero?.paragraphInternalId}
      parentId={pageData?.pageInternalId}
      bundle={hero?.bundle}
    />
    <section class="form-section">
      <div class="form-container">
        <ForgotPasswordForm
          lang="es"
          formTitle={formHeader?.title}
          formSubtitle={formHeader?.subtitle}
          formParagraphId={formHeader?.paragraphId}
          formParagraphInternalId={formHeader?.paragraphInternalId}
          formParentId={formHeader?.parentId}
          client:load
        />
      </div>
    </section>
  </main>
</AuthLayout>

<style>
  .auth-main { display: flex; height: 100vh; overflow: hidden; }
  .form-section { width: 100%; display: flex; flex-direction: column; background: white; overflow-y: auto; }
  @media (min-width: 1024px) { .form-section { width: 50%; } }
  .form-container { flex: 1; display: flex; align-items: center; justify-content: center; padding: 2.5rem 1.5rem; }
  @media (min-width: 640px) { .form-container { padding: 2.5rem 3rem; } }
  @media (min-width: 768px) { .form-container { padding: 2.5rem 6rem; } }
</style>
