---
export const prerender = false;

import ProductDetailContent from '@/components/pages/ProductDetailContent.astro';
import { getProductDetailPageData } from '@/services/nodehive/nodehive.product';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;
const { id } = Astro.params;
if (!id) return Astro.redirect('/es/');

const data = await getProductDetailPageData(id, lang);
if (!data) return Astro.redirect('/es/');
---
<ProductDetailContent lang={lang} {...data} />