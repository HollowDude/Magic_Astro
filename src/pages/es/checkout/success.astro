---
export const prerender = false;

import HomeLayout from '@/layouts/HomeLayout.astro';
import { getSession } from '@/services/session.service';
import { getLangFromUrl } from '@/i18n/utils';
import { getFooterContactData } from '@/services/nodehive/nodehive.footer';

const lang = getLangFromUrl(Astro.url);
const session = await getSession(Astro.cookies);

if (!session) {
  return Astro.redirect(`/es/login?redirect=/es/checkout/success`);
}

const orderNumber = Astro.url.searchParams.get('order') ?? '';
const drupalOrderId = Astro.url.searchParams.get('orderId') ?? '';
const paypalToken = Astro.url.searchParams.get('token') ?? '';

// ── Cargar datos de la orden desde Drupal ──
interface OrderItem {
  itemId: number;
  title: string;
  quantity: number;
  unitPrice: string;
  totalPrice: string;
  thumbnailUrl: string | null;
  hasCard: boolean;
  cardMessage: string | null;
  ribbonColor: { name: string; hex: string } | null;
}

let orderItems: OrderItem[] = [];
let checkoutData: Record<string, any> | null = null;
let orderTotalPrice = '';
let orderSubtotalPrice = '';

if (drupalOrderId && session?.accessToken) {
  try {
    const baseUrl = (import.meta.env.NODEHIVE_BASE_URL as string).replace(/\/+$/, '');

    // 1. Cargar la orden con sus items incluidos
    const orderRes = await fetch(
      `${baseUrl}/en/jsonapi/commerce_order/default/${drupalOrderId}` +
      `?include=order_items` +
      `&fields[commerce_order--default]=total_price,field_checkout_data,order_items` +
      `&fields[commerce_order_item--default]=drupal_internal__order_item_id,title,quantity,unit_price,total_price,purchased_entity,field_has_card,field_card_message,field_ribbon_color`,
      {
        headers: {
          Accept: 'application/vnd.api+json',
          Authorization: `Bearer ${session.accessToken}`,
        },
      },
    );

    if (orderRes.ok) {
      const orderJson = await orderRes.json();
      const attrs = orderJson?.data?.attributes ?? {};
      const included = Array.isArray(orderJson?.included) ? orderJson.included : [];
      const rels = orderJson?.data?.relationships?.order_items?.data ?? [];

      orderTotalPrice = attrs.total_price?.formatted ?? '';

      // Parsear checkout data
      if (attrs.field_checkout_data) {
        try { checkoutData = JSON.parse(attrs.field_checkout_data); } catch {}
      }

      // Obtener variationUuids para thumbnails
      const variationUuids: string[] = [];
      const rawItems: Array<{ inc: any; itemId: number; variationUuid: string | null }> = [];

      for (const rel of rels) {
        const inc = included.find((i: any) => i.type === rel.type && i.id === rel.id);
        if (!inc) continue;
        const a = inc?.attributes ?? {};
        const itemId = a.drupal_internal__order_item_id;
        if (!itemId) continue;
        const variationUuid = inc?.relationships?.purchased_entity?.data?.id ?? null;
        if (variationUuid) variationUuids.push(variationUuid);
        rawItems.push({ inc, itemId, variationUuid });
      }

      // 2. Cargar thumbnails si hay variaciones
      const thumbnailMap = new Map<string, string>();
      if (variationUuids.length > 0) {
        try {
          const valueParams = variationUuids.map(u => `filter[id][condition][value][]=${encodeURIComponent(u)}`).join('&');
          const thumbRes = await fetch(
            `${baseUrl}/jsonapi/commerce_product_variation/flower?filter[id][condition][path]=id&filter[id][condition][operator]=IN&${valueParams}&include=field_gallery_of_photos,field_gallery_of_photos.field_media_image`,
            { headers: { Accept: 'application/vnd.api+json' } },
          );
          if (thumbRes.ok) {
            const thumbJson = await thumbRes.json();
            const thumbIncluded = Array.isArray(thumbJson?.included) ? thumbJson.included : [];
            for (const item of thumbJson?.data ?? []) {
              const firstMediaId = item?.relationships?.field_gallery_of_photos?.data?.[0]?.id;
              if (!firstMediaId) continue;
              const media = thumbIncluded.find((i: any) => i.type === 'media--image' && i.id === firstMediaId);
              const fileId = media?.relationships?.field_media_image?.data?.id;
              if (!fileId) continue;
              const file = thumbIncluded.find((i: any) => i.type === 'file--file' && i.id === fileId);
              if (file?.attributes?.uri?.url) {
                thumbnailMap.set(item.id, `${baseUrl}${file.attributes.uri.url}`);
              }
            }
          }
        } catch {}
      }

      // 3. Cargar colores de cinta
      const ribbonRes = await fetch(`${baseUrl}/jsonapi/taxonomy_term/ribbon_color?fields[taxonomy_term--ribbon_color]=name,field_hex_color`, {
        headers: { Accept: 'application/vnd.api+json' },
      }).catch(() => null);
      const ribbonMap = new Map<string, { name: string; hex: string }>();
      if (ribbonRes?.ok) {
        const rj = await ribbonRes.json();
        for (const t of rj?.data ?? []) {
          ribbonMap.set(t.id, { name: t.attributes?.name ?? '', hex: t.attributes?.field_hex_color ?? '#ccc' });
        }
      }

      // 4. Construir items finales
      orderItems = rawItems.map(({ inc, itemId, variationUuid }) => {
        const a = inc?.attributes ?? {};
        const ribbonRelId = inc?.relationships?.field_ribbon_color?.data?.id ?? null;
        return {
          itemId,
          title: a.title ?? '',
          quantity: Math.round(parseFloat(a.quantity ?? '1')),
          unitPrice: a.unit_price?.formatted ?? '',
          totalPrice: a.total_price?.formatted ?? '',
          thumbnailUrl: thumbnailMap.get(variationUuid ?? '') ?? null,
          hasCard: a.field_has_card ?? false,
          cardMessage: a.field_card_message ?? null,
          ribbonColor: ribbonRelId ? (ribbonMap.get(ribbonRelId) ?? null) : null,
        };
      });
    }
  } catch (e) {
    // fail silently — la página sigue mostrando el número de orden
  }
}

// Calcular subtotal y costo de envío desde checkoutData
function parseMoney(value: string): number {
  if (!value) return 0;
  const cleaned = value.replace(/[^0-9.,-]/g, '').replace(',', '.');
  const parsed = parseFloat(cleaned);
  return Number.isFinite(parsed) ? parsed : 0;
}
function fmt(amount: number): string {
  return `$${amount.toFixed(2)}`;
}

const shippingCost = checkoutData?.shippingCost ?? (checkoutData?.shippingMethod === 'delivery' ? 24 : 0);
const shippingFormatted = shippingCost > 0 ? fmt(shippingCost) : (lang === 'es' ? 'Gratis' : 'Free');
const subtotalNum = parseMoney(orderTotalPrice);
const grandTotalNum = subtotalNum + shippingCost;
const grandTotalFormatted = fmt(grandTotalNum);

// ── Cargar dirección de la tienda desde Drupal (para pickup) ──
const contactData = await getFooterContactData(lang);
const storeAddress = contactData?.address
  ? [contactData.address.line1, contactData.address.line2, contactData.address.line3, contactData.address.postalCode].filter(Boolean).join(', ')
  : '';
---

<HomeLayout title="Pedido confirmado — Maggy Flowers" lang={lang}>
  <div class="scp-page">

    {/* ── Cabecera de confirmación ── */}
    <div class="scp-hero">
      <div class="scp-icon-wrap">
        <span class="material-symbols-outlined scp-icon">check_circle</span>
      </div>
      <h1 class="scp-title">{lang === 'es' ? '¡Pedido confirmado!' : 'Order confirmed!'}</h1>
      <p class="scp-subtitle">{lang === 'es' ? 'Recibirás un correo con los detalles de tu pedido.' : 'You\'ll receive a confirmation email shortly.'}</p>
      {orderNumber && (
        <div class="scp-order-badge">
          <span class="scp-order-label">{lang === 'es' ? 'Número de pedido' : 'Order number'}</span>
          <span class="scp-order-number">{orderNumber}</span>
        </div>
      )}
    </div>

    <div class="scp-body">

      {/* ── Columna principal ── */}
      <div class="scp-main">

        {/* Productos */}
        {orderItems.length > 0 && (
          <section class="scp-card">
            <h2 class="scp-card-title">
              <span class="material-symbols-outlined scp-card-icon">shopping_bag</span>
              {lang === 'es' ? 'Productos' : 'Items'} ({orderItems.length})
            </h2>
            <div class="scp-items">
              {orderItems.map(item => (
                <div class="scp-item">
                  <div class="scp-item-thumb">
                    {item.thumbnailUrl
                      ? <img src={item.thumbnailUrl} alt={item.title} class="scp-thumb-img" loading="lazy" />
                      : <span class="material-symbols-outlined scp-thumb-fallback">local_florist</span>
                    }
                    <span class="scp-item-qty">{item.quantity}</span>
                  </div>
                  <div class="scp-item-info">
                    <p class="scp-item-title">{item.title}</p>
                    <p class="scp-item-unit">{item.unitPrice} {lang === 'es' ? 'c/u' : 'each'}</p>
                    {(item.hasCard || item.ribbonColor) && (
                      <div class="scp-item-badges">
                        {item.hasCard && (
                          <span class="scp-badge scp-badge--card">
                            <span class="material-symbols-outlined" style="font-size:0.875rem">mail</span>
                            {item.cardMessage ? `"${item.cardMessage.slice(0, 30)}${item.cardMessage.length > 30 ? '…' : ''}"` : (lang === 'es' ? 'Con tarjeta' : 'With card')}
                          </span>
                        )}
                        {item.ribbonColor && (
                          <span class="scp-badge scp-badge--ribbon">
                            <span class="scp-ribbon-dot" style={`background:${item.ribbonColor.hex}`}></span>
                            {lang === 'es' ? 'Cinta' : 'Ribbon'}: {item.ribbonColor.name}
                          </span>
                        )}
                      </div>
                    )}
                  </div>
                  <span class="scp-item-total">{item.totalPrice}</span>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* Entrega */}
        {checkoutData && (
          <section class="scp-card">
            <h2 class="scp-card-title">
              <span class="material-symbols-outlined scp-card-icon">
                {checkoutData.shippingMethod === 'pickup' ? 'store' : 'local_shipping'}
              </span>
              {lang === 'es' ? 'Información de entrega' : 'Delivery information'}
            </h2>

            <div class="scp-delivery-grid">
              <div class="scp-delivery-row">
                <span class="scp-delivery-label">{lang === 'es' ? 'Método' : 'Method'}</span>
                <span class="scp-delivery-value scp-delivery-method">
                  {checkoutData.shippingMethod === 'pickup'
                    ? (lang === 'es' ? 'Recogida en tienda' : 'Store pickup')
                    : (lang === 'es' ? 'Delivery a domicilio' : 'Home delivery')}
                </span>
              </div>

              {checkoutData.shippingMethod !== 'pickup' && checkoutData.shippingAddress && (
                <div class="scp-delivery-row">
                  <span class="scp-delivery-label">{lang === 'es' ? 'Dirección' : 'Address'}</span>
                  <span class="scp-delivery-value">
                    {[
                      [checkoutData.shippingAddress.firstName, checkoutData.shippingAddress.lastName].filter(Boolean).join(' '),
                      checkoutData.shippingAddress.addressLine1,
                      checkoutData.shippingAddress.city,
                      checkoutData.shippingAddress.state,
                      checkoutData.shippingAddress.postalCode,
                    ].filter(Boolean).join(', ')}
                  </span>
                </div>
              )}

              {checkoutData.shippingMethod === 'pickup' && (
                <div class="scp-delivery-row">
                  <span class="scp-delivery-label">{lang === 'es' ? 'Ubicación' : 'Location'}</span>
                  <span class="scp-delivery-value">{storeAddress || (lang === 'es' ? 'Av. Principal Las Mercedes, Local 4B' : 'Av. Principal Las Mercedes, Local 4B')}</span>
                </div>
              )}

              <div class="scp-delivery-row">
                <span class="scp-delivery-label">{lang === 'es' ? 'Tiempo estimado' : 'Estimated time'}</span>
                <span class="scp-delivery-value scp-delivery-eta">
                  <span class="material-symbols-outlined" style="font-size:1rem;color:var(--sage)">schedule</span>
                  {checkoutData.shippingMethod === 'pickup'
                    ? (lang === 'es' ? 'Disponible en 24 horas' : 'Available in 24 hours')
                    : (lang === 'es' ? '1 a 3 días hábiles' : '1 to 3 business days')}
                </span>
              </div>
            </div>
          </section>
        )}

        {/* Método de pago */}
        {checkoutData?.paymentMethod && (
          <section class="scp-card">
            <h2 class="scp-card-title">
              <span class="material-symbols-outlined scp-card-icon">credit_card</span>
              {lang === 'es' ? 'Método de pago' : 'Payment method'}
            </h2>
            <div class="scp-payment-row">
              <div class="scp-payment-logos">
                <img src="https://cdn.jsdelivr.net/gh/maggyflowers/maggy-assets/icons/visa.svg" alt="VISA" class="scp-card-logo" />
                <img src="https://cdn.jsdelivr.net/gh/maggyflowers/maggy-assets/icons/mastercard.svg" alt="MC" class="scp-card-logo" />
              </div>
              <span class="scp-payment-name">
                {lang === 'es' ? 'Tarjeta de crédito/débito vía PayPal' : 'Credit/debit card via PayPal'}
              </span>
              <span class="scp-payment-secure">
                <span class="material-symbols-outlined" style="font-size:0.875rem">lock</span>
                {lang === 'es' ? 'Pago seguro' : 'Secure payment'}
              </span>
            </div>
          </section>
        )}

      </div>

      {/* ── Sidebar de totales ── */}
      <aside class="scp-sidebar">
        <div class="scp-card scp-totals-card">
          <h2 class="scp-card-title">
            <span class="material-symbols-outlined scp-card-icon">receipt_long</span>
            {lang === 'es' ? 'Resumen del pago' : 'Payment summary'}
          </h2>

          <div class="scp-totals">
            {orderItems.length > 0 && (
              <div class="scp-total-row">
                <span>{lang === 'es' ? 'Subtotal' : 'Subtotal'}</span>
                <span>{orderTotalPrice || '—'}</span>
              </div>
            )}
            {checkoutData && (
              <div class="scp-total-row">
                <span>{lang === 'es' ? 'Envío' : 'Shipping'}</span>
                <span class={shippingCost === 0 ? 'scp-free' : ''}>{shippingFormatted}</span>
              </div>
            )}
            <div class="scp-total-row scp-total-row--final">
              <span>{lang === 'es' ? 'Total pagado' : 'Total paid'}</span>
              <span>{grandTotalFormatted || orderTotalPrice || '—'}</span>
            </div>
          </div>

          <div class="scp-actions">
            <a href={`/${lang}/shop`} class="btn-primary scp-btn-shop">
              <span class="material-symbols-outlined" style="font-size:1.125rem">shopping_bag</span>
              {lang === 'es' ? 'Seguir comprando' : 'Continue shopping'}
            </a>
            <a href={`/${lang}/dashboard/orders`} class="scp-link-orders">
              <span class="material-symbols-outlined" style="font-size:1rem">receipt_long</span>
              {lang === 'es' ? 'Ver mis pedidos' : 'View my orders'}
            </a>
          </div>
        </div>
      </aside>

    </div>
  </div>
</HomeLayout>

<script>
  const paypalToken = new URLSearchParams(window.location.search).get('token');
  const drupalOrderId = new URLSearchParams(window.location.search).get('orderId');

  if (paypalToken) {
    fetch('/api/checkout/paypal-capture', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        paypalOrderId: paypalToken,
        drupalOrderUuid: drupalOrderId || null,
        drupalOrderId: drupalOrderId || null,
      }),
    }).catch(() => {});
  }
</script>

<style>
  .scp-page {
    min-height: 70vh;
    max-width: 58rem;
    margin: 0 auto;
    padding: 2.5rem 1rem 4rem;
  }

  /* ── Hero ── */
  .scp-hero {
    text-align: center;
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .scp-icon-wrap {
    width: 5rem; height: 5rem;
    border-radius: 50%;
    background: color-mix(in srgb, var(--primary) 10%, transparent);
    display: flex; align-items: center; justify-content: center;
  }
  .scp-icon {
    font-size: 2.75rem !important;
    color: var(--primary);
  }
  .scp-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 600;
    color: var(--headline);
  }
  .scp-subtitle {
    font-size: 0.9375rem;
    color: var(--text-muted);
    max-width: 30rem;
  }
  .scp-order-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    background: var(--blush);
    border: 1.5px solid color-mix(in srgb, var(--primary) 20%, transparent);
    border-radius: 1rem;
    padding: 0.875rem 2rem;
    margin-top: 0.25rem;
  }
  .scp-order-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
  }
  .scp-order-number {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--headline);
  }

  /* ── Layout body ── */
  .scp-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .scp-body { grid-template-columns: 1fr 22rem; align-items: start; }
  }

  .scp-main { display: flex; flex-direction: column; gap: 1.25rem; }

  /* ── Cards ── */
  .scp-card {
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 1rem;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 2px 12px rgba(109,81,87,0.05);
  }
  .scp-card-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: 1.125rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .scp-card-icon { font-size: 1.125rem !important; color: var(--primary); }

  /* ── Items ── */
  .scp-items { display: flex; flex-direction: column; gap: 0; }
  .scp-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 0;
    border-bottom: 1px solid var(--border);
  }
  .scp-item:last-child { border-bottom: none; }
  .scp-item-thumb {
    position: relative;
    width: 3.5rem; height: 3.5rem;
    border-radius: 0.625rem;
    overflow: hidden;
    background: var(--blush);
    border: 1px solid var(--border);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .scp-thumb-img { width: 100%; height: 100%; object-fit: cover; }
  .scp-thumb-fallback { font-size: 1.375rem !important; color: var(--primary); opacity: 0.4; }
  .scp-item-qty {
    position: absolute;
    top: -4px; right: -4px;
    background: var(--primary); color: white;
    font-size: 0.625rem; font-weight: 700;
    width: 1.125rem; height: 1.125rem;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .scp-item-info { flex: 1; min-width: 0; }
  .scp-item-title {
    font-size: 0.875rem; font-weight: 600;
    color: var(--headline);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .scp-item-unit { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.125rem; }
  .scp-item-badges { display: flex; flex-wrap: wrap; gap: 0.375rem; margin-top: 0.375rem; }
  .scp-badge {
    display: inline-flex; align-items: center; gap: 0.25rem;
    font-size: 0.6875rem; font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
  }
  .scp-badge--card {
    background: color-mix(in srgb, var(--primary) 8%, transparent);
    color: var(--primary);
  }
  .scp-badge--ribbon {
    background: var(--blush);
    color: var(--text-muted);
  }
  .scp-ribbon-dot {
    width: 0.5rem; height: 0.5rem;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.12);
    flex-shrink: 0;
  }
  .scp-item-total {
    font-family: var(--font-body);
    font-size: 0.9375rem; font-weight: 700;
    color: var(--headline); flex-shrink: 0;
  }

  /* ── Delivery ── */
  .scp-delivery-grid { display: flex; flex-direction: column; gap: 0.75rem; }
  .scp-delivery-row {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 1rem;
    font-size: 0.875rem;
  }
  .scp-delivery-label {
    font-weight: 600; color: var(--text-muted);
    flex-shrink: 0; min-width: 6rem;
  }
  .scp-delivery-value { color: var(--headline); text-align: right; }
  .scp-delivery-method { color: var(--primary); font-weight: 700; }
  .scp-delivery-eta {
    display: flex; align-items: center; gap: 0.25rem;
    color: var(--sage); font-weight: 600;
  }

  /* ── Payment ── */
  .scp-payment-row {
    display: flex; align-items: center; flex-wrap: wrap;
    gap: 0.75rem;
  }
  .scp-payment-logos { display: flex; gap: 0.375rem; }
  .scp-card-logo { height: 1.25rem; }
  .scp-payment-name { font-size: 0.875rem; color: var(--headline); font-weight: 600; flex: 1; }
  .scp-payment-secure {
    display: flex; align-items: center; gap: 0.25rem;
    font-size: 0.75rem; color: var(--sage); font-weight: 600;
  }

  /* ── Totals sidebar ── */
  .scp-sidebar { position: sticky; top: 6rem; }
  .scp-totals-card { }
  .scp-totals { display: flex; flex-direction: column; gap: 0.625rem; margin-bottom: 1.25rem; }
  .scp-total-row {
    display: flex; justify-content: space-between;
    font-size: 0.9375rem; color: var(--text-muted);
  }
  .scp-free { color: var(--sage); font-weight: 600; }
  .scp-total-row--final {
    font-size: 1.125rem; font-weight: 800;
    color: var(--headline);
    padding-top: 0.75rem;
    margin-top: 0.25rem;
    border-top: 2px solid var(--border);
  }
  .scp-total-row--final span:last-child { color: var(--primary); }

  .scp-actions { display: flex; flex-direction: column; gap: 0.625rem; }
  .scp-btn-shop {
    width: 100%; height: 3.125rem;
    font-size: 0.9375rem; font-weight: 700;
    border-radius: 0.75rem;
    box-shadow: 0 4px 16px color-mix(in srgb, var(--primary) 30%, transparent);
  }
  .scp-link-orders {
    display: flex; align-items: center; justify-content: center; gap: 0.375rem;
    font-size: 0.875rem; font-weight: 600;
    color: var(--text-muted); text-decoration: none;
    transition: color 0.15s;
