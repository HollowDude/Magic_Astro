---
// src/components/pages/HelpPageContent.astro
import HomeLayout from '@/layouts/HomeLayout.astro';
import { getHelpPageData } from '@/services/nodehive/nodehive.help';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

// Automatically detect language from URL or Astro context
const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;

// Automatically detect slug from URL path (e.g., /es/faq -> faq, /en/shipping -> shipping)
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const slug = pathSegments.pop() ?? '';

const data = await getHelpPageData(slug, lang);

const fallbackTitle = slug.replace(/-/g, ' ');
const title = data?.title ?? fallbackTitle;
---

<HomeLayout title={title} lang={lang}>
  <main class="main-container">
    <article
      data-nodehive-entity-type={data ? 'paragraph' : undefined}
      data-nodehive-entity-bundle={data ? '_component_footer_help' : undefined}
      data-nodehive-entity-id={data?.paragraphId ?? undefined}
      data-nodehive-entity-internal-id={data?.paragraphInternalId ?? undefined}
      data-nodehive-parent_id={data?.pageInternalId ?? undefined}
    >
      <h1
        class="font-heading text-[clamp(2rem,4vw,3rem)] font-semibold tracking-tight text-headline leading-tight mb-8"
        data-nodehive-field="field_title"
      >
        {title}
      </h1>

      {data?.body ? (
        <div
          class="prose-help"
          data-nodehive-field="field_body"
          set:html={data.body}
        />
      ) : (
        <p class="text-body-color">
          {lang === 'en' ? 'Content coming soon.' : 'Contenido próximamente.'}
        </p>
      )}
    </article>
  </main>
</HomeLayout>

<style>
  /* Estilos para el rich text del field_body */
  .prose-help {
    font-family: var(--font-body);
    color: var(--body-color);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 80rem;
  }
  .prose-help h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--headline);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-help h3 {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--headline);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-help p { margin-bottom: 1rem; }
  .prose-help ul, .prose-help ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .prose-help li { margin-bottom: 0.375rem; }
  .prose-help a {
    color: var(--primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-help a:hover { color: var(--primary-dark); }
  .prose-help strong { color: var(--headline); font-weight: 700; }
</style>