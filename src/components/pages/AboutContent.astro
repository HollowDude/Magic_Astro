---
import HomeLayout from '@/layouts/HomeLayout.astro';
import { useTranslations, getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';
import {
  getAboutHeroData,
  getAboutStoryData,
  getAboutArchievementsData,
  getAboutCertificactionData,
  getAboutIdentityData,
  getAboutObjectifsData,
} from '@/services/nodehive/nodehive.paragraphs';

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;

const [hero, story, archievements, cert, identity, objectifs] = await Promise.all([
  getAboutHeroData(lang),
  getAboutStoryData(lang),
  getAboutArchievementsData(lang),
  getAboutCertificactionData(lang),
  getAboutIdentityData(lang),
  getAboutObjectifsData(lang),
]);

const parentId = hero?.parentId
  ?? story?.parentId
  ?? archievements?.parentId
  ?? cert?.parentId
  ?? identity?.parentId
  ?? objectifs?.parentId
  ?? null;

const isEn = lang === 'en';
const pageTitle = isEn ? 'About Us' : 'Sobre Nosotros';
const heroTitle = hero?.title ?? (isEn ? 'About Us' : 'Sobre Nosotros');
const heroSubtitle = hero?.subtitle ?? (isEn ? 'Floral design with magic, soul and purpose' : 'Diseño floral con magia, alma y propósito');
const storyTitle = story?.title ?? (isEn ? 'Our Story' : 'Nuestra historia');
const storyDesc = story?.description ?? (isEn
  ? 'Maggy Flowers was born from a passion that became purpose: creating magic with flowers. With over 15 years of experience, Maggy has worked with both natural and artificial flowers, designing arrangements to gift, decorate homes and transform events. She studied event and wedding planning at Miami Dade College, specializing in design for memorable moments. What excites her most is creating one-of-a-kind arrangements with what she has at hand, because for her, designing flowers is pure magic. Over time, her mission evolved: not only to create, but also to teach. Today, Maggy Flowers is a floral studio and academy that inspires entrepreneurial women to monetize their floral talent through digital courses, online classes and in-person workshops. Her community is active, supportive and full of good vibes, with a practical, traditional and innovative approach at the same time.'
  : 'Maggy Flowers nació de una pasión que se convirtió en propósito: crear magia con flores. Con más de 15 años de experiencia, Maggy ha trabajado tanto con flores naturales como artificiales, diseñando arreglos para regalar, decorar hogares y transformar eventos. Estudió planificación de eventos y bodas en Miami Dade College, especializándose en diseño para momentos memorables. Lo que más la emociona es crear arreglos irrepetibles con lo que tiene a la mano, porque para ella, diseñar flores es pura magia. Con el tiempo, su misión evolucionó: no solo crear, sino también enseñar. Hoy, Maggy Flowers es un estudio floral y academia que inspira a mujeres emprendedoras a monetizar su talento floral a través de cursos digitales, clases online y talleres presenciales. Su comunidad es activa, solidaria y llena de buenas vibras, con un enfoque práctico, tradicional e innovador a la vez.');
const archTitle = archievements?.title ?? (isEn ? 'Our Achievements' : 'Nuestros logros');
const certTitle = cert?.title ?? (isEn ? 'Certifications' : 'Certificaciones');
const certSubtitle = cert?.subtitle ?? (isEn ? 'Event & wedding planning training – Miami Dade College' : 'Formación en planificación de eventos y bodas – Miami Dade College');
const identityTitle = identity?.title ?? (isEn ? 'Identity & Values' : 'Identidad y Valores');
const identitySubtitle = identity?.subtitle ?? (isEn ? 'Our DNA' : 'Nuestro ADN');
---

<HomeLayout title={pageTitle}>
  <div class="min-h-screen flex flex-col">
    <main class="flex-1">

      <!-- SECTION 1: HERO -->
      <section
        class="about-hero relative w-full h-[260px] sm:h-[300px] lg:h-[340px] flex items-center justify-center flex-col text-center overflow-hidden px-4 sm:px-6"
        data-nodehive-entity-type="paragraph"
        data-nodehive-entity-bundle="_component_about_hero"
        data-nodehive-entity-id={hero?.paragraphId ?? null}
        data-nodehive-entity-internal-id={hero?.paragraphInternalId ?? null}
        data-nodehive-parent_id={parentId ?? null}
      >
        {hero?.fotoUrl ? (
          <>
            <img
              src={hero.fotoUrl}
              alt=""
              class="absolute inset-0 w-full h-full object-cover"
              aria-hidden="true"
            />
            <div class="absolute inset-0" style="background: rgba(140,50,65,0.52);"></div>
          </>
        ) : (
          <div class="absolute inset-0 bg-gradient-to-br from-[#f2a4a4] via-[#e8889a] to-[#d4778a]">
            <div class="absolute inset-0" style="background-image: radial-gradient(ellipse 120px 100px at 20% 80%, rgba(235,71,99,0.35) 0%, transparent 70%), radial-gradient(ellipse 180px 160px at 50% 70%, rgba(220,60,90,0.25) 0%, transparent 70%), radial-gradient(ellipse 100px 90px at 80% 85%, rgba(235,71,99,0.30) 0%, transparent 70%);"></div>
            <div class="absolute inset-0" style="background: rgba(180,80,95,0.38);"></div>
          </div>
        )}
        <div class="relative z-10 text-center">
          <h1 class="font-heading font-semibold text-[40px] sm:text-[56px] lg:text-[72px] text-white leading-[1.05] sm:leading-[1.1] tracking-[-1px]" data-nodehive-field="field_title">{heroTitle}</h1>
          <p class="font-body font-medium text-[16px] sm:text-[20px] lg:text-[22px] text-white mt-2 sm:mt-3 tracking-wide max-w-[720px] mx-auto" data-nodehive-field="field_subtitle">{heroSubtitle}</p>
        </div>
      </section>

      <!-- SECTION 2: HISTORIA -->
      <section
        class="bg-white py-0"
        data-nodehive-entity-type="paragraph"
        data-nodehive-entity-bundle="_component_about_story"
        data-nodehive-entity-id={story?.paragraphId ?? null}
        data-nodehive-entity-internal-id={story?.paragraphInternalId ?? null}
        data-nodehive-parent_id={parentId ?? null}
      >
        <div class="max-w-[1300px] mx-auto px-[6%] sm:px-[8%] py-[60px] sm:py-[90px] flex flex-col lg:flex-row items-center lg:items-start gap-10 sm:gap-12 lg:gap-20">
          <div class="relative flex-shrink-0 w-full max-w-[450px] h-[320px] sm:h-[420px] lg:h-[700px] mx-auto lg:mx-0">
            <div class="absolute border-[2.5px] border-primary rounded-[20px] w-[88%] h-[72%] sm:w-[390px] sm:h-[545px] top-4 sm:top-6 right-[-12px] sm:right-[-24px] z-[1]"></div>
            {story?.fotoUrl ? (
              <div class="absolute bottom-0 left-0 sm:left-[-20px] z-[2] w-[88%] h-[78%] sm:w-[390px] sm:h-[575px] rounded-[20px] overflow-hidden">
                <img src={story.fotoUrl} alt={storyTitle} class="w-full h-full object-cover" />
              </div>
            ) : (
              <div class="absolute bottom-0 left-0 sm:left-[-20px] z-[2] w-[88%] h-[78%] sm:w-[390px] sm:h-[575px] rounded-[20px] overflow-hidden flex items-end justify-center" style="background: linear-gradient(160deg, #f8c5c5 0%, #f2a0a0 40%, #e88888 100%);">
                <span class="text-[120px] absolute bottom-5 opacity-60">🌸</span>
              </div>
            )}
          </div>
          <div class="flex-1 pt-6 lg:pt-3 text-center lg:text-left">
            <p class="font-body font-semibold text-[13px] sm:text-[16px] lg:text-[18px] text-primary tracking-[1.5px] uppercase mb-2.5" data-nodehive-field="field_subtitle_primary">Maggy Flowers</p>
            <h2 class="font-heading font-semibold text-[32px] sm:text-[42px] lg:text-[52px] text-headline leading-[1.1] mb-5 sm:mb-7" data-nodehive-field="field_title">{storyTitle}</h2>
            <p class="font-body text-[16px] sm:text-[18px] leading-[30px] sm:leading-[34px] lg:leading-[38px] text-body-color" data-nodehive-field="field_description_long">{storyDesc}</p>
          </div>
        </div>
      </section>

      <!-- SECTION 3: LOGROS -->
      <section
        class="relative py-[50px] sm:py-[70px] px-[6%] sm:px-[8%] text-center"
        data-nodehive-entity-type="paragraph"
        data-nodehive-entity-bundle="_component_about_archievements"
        data-nodehive-entity-id={archievements?.paragraphId ?? null}
        data-nodehive-entity-internal-id={archievements?.paragraphInternalId ?? null}
        data-nodehive-parent_id={parentId ?? null}
      >
        <button
          type="button"
          class="nh-only absolute top-4 right-4 z-10 inline-flex items-center gap-2 rounded-full border border-primary/25 bg-white/90 px-3.5 py-1.5 text-xs font-semibold text-primary shadow-sm hover:bg-white"
          data-nodehive-field="field_title"
        >
          <span class="material-symbols-outlined text-[14px]">edit</span>
          Editar seccion
        </button>
        <h2 class="font-heading font-semibold text-[32px] sm:text-[44px] lg:text-[52px] text-headline mb-8 sm:mb-12" data-nodehive-field="field_title">{archTitle}</h2>
        <div class="flex justify-center gap-6 sm:gap-8 flex-wrap">
          {(archievements?.items ?? [
            { id: 'amazon', icon: '📦', title: 'Amazon Influencer', description: isEn ? 'approved' : 'aprobada' },
            { id: 'hotmart', icon: '🔥', title: isEn ? 'Floral design courses' : 'Cursos de diseño floral', description: 'Hotmart' },
            { id: 'vip', icon: '👑', title: isEn ? 'Active VIP community of entrepreneurial women' : 'Comunidad VIP activa de\r\nalumnas emprendedoras', description: '' },
          ]).map((item: any) => (
            <div class="flex flex-col items-center gap-4 sm:gap-5 w-full max-w-[340px]">
              <div class="bg-white rounded-2xl shadow-[6px_6px_20px_rgba(0,0,0,0.08)] px-8 sm:px-12 py-7 sm:py-9 w-full flex items-center justify-center min-h-[96px] sm:min-h-[110px]">
                <div class="font-body font-semibold text-[15px] sm:text-[17px] text-[#555] flex items-center gap-2">
                  {item.id === 'amazon' ? (
                    <div class="flex items-center gap-2">
                      <span class="text-[22px]">📦</span>
                      <div>
                        <div class="text-[13px] sm:text-[14px] font-bold text-[#232f3e]">amazon</div>
                        <div class="text-[10px] sm:text-[11px] text-[#555]">influencers</div>
                      </div>
                    </div>
                  ) : item.id === 'hotmart' ? (
                    <div class="flex items-center gap-2">
                      <div class="w-[28px] h-[28px] sm:w-[30px] sm:h-[30px] bg-[#FF543E] rounded-full flex items-center justify-center text-white text-[15px] sm:text-[16px] font-bold">🔥</div>
                      <span>hotmart</span>
                    </div>
                  ) : (
                    <div class="flex items-center gap-2">
                      <span class="text-[18px] sm:text-[20px]">👑</span>
                      <span class="font-bold tracking-[1px] border border-[#bbb] rounded-md px-2 py-1 text-[13px] sm:text-[15px]">COMUNIDAD VIP</span>
                    </div>
                  )}
                </div>
              </div>
              <p class="text-[15px] sm:text-[16px] font-semibold text-primary leading-[1.4] text-center whitespace-pre-line">{item.title}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- SECTION 4: CERTIFICACIONES -->
      <section
        class="bg-sage px-[6%] sm:px-[8%] py-10 sm:py-11 flex flex-col md:flex-row items-center gap-4 md:gap-0 text-center md:text-left"
        data-nodehive-entity-type="paragraph"
        data-nodehive-entity-bundle="_component_about_certificaction"
        data-nodehive-entity-id={cert?.paragraphId ?? null}
        data-nodehive-entity-internal-id={cert?.paragraphInternalId ?? null}
        data-nodehive-parent_id={parentId ?? null}
      >
        <h2 class="font-heading font-semibold text-[28px] sm:text-[34px] md:text-[42px] text-white md:whitespace-nowrap" data-nodehive-field="field_title">{certTitle}</h2>
        <div class="w-[60px] h-[2px] md:w-[2px] md:h-20 bg-white/50 my-4 md:my-0 mx-0 md:mx-12 flex-shrink-0"></div>

        {cert?.fotoUrl ? (
          <div class="flex-shrink-0 w-[100px] h-[75px] sm:w-[120px] sm:h-[90px] rounded-xl overflow-hidden mr-0 md:mr-10">
            <img src={cert.fotoUrl} alt={certTitle ?? ''} class="w-full h-full object-cover" />
          </div>
        ) : null}

        <p class="font-body text-[18px] sm:text-[20px] md:text-[22px] font-normal text-white leading-[1.5]" data-nodehive-field="field_subtitle">{certSubtitle}</p>
      </section>

      <!-- SECTION 5: OBJETIVOS -->
      {objectifs && objectifs.items.length > 0 && (
        <section
          class="bg-white relative"
          data-nodehive-entity-type="paragraph"
          data-nodehive-entity-bundle="_component_about_objetives"
          data-nodehive-entity-id={objectifs.paragraphId ?? null}
          data-nodehive-entity-internal-id={objectifs.paragraphInternalId ?? null}
          data-nodehive-parent_id={parentId ?? null}
        >
          <button
            type="button"
            class="nh-only absolute top-4 right-4 sm:top-6 sm:right-6 z-10 inline-flex items-center gap-2 rounded-full border border-primary/25 bg-white/90 px-3.5 py-1.5 text-xs font-semibold text-primary shadow-sm hover:bg-white"
            data-nodehive-field="field_title"
          >
            <span class="material-symbols-outlined text-[14px]">edit</span>
            Editar seccion
          </button>
          <div class="max-w-[1300px] mx-auto px-[6%] sm:px-[8%] py-[60px] sm:py-[90px] flex flex-col gap-[50px] sm:gap-[70px]">
            {objectifs.title && (
              <h2 class="font-heading font-semibold text-[32px] sm:text-[44px] lg:text-[52px] text-headline text-center mb-0" data-nodehive-field="field_title">
                {objectifs.title}
              </h2>
            )}
            {objectifs.items.map((item, index) => {
              const isEven = index % 2 === 0;
              return (
                <div class={`flex flex-col lg:flex-row items-center gap-10 sm:gap-12 lg:gap-[70px] ${isEven ? '' : 'lg:flex-row-reverse'}`}>
                  <div class="flex-1 text-center lg:text-left">
                    {item.title && <h3 class="font-heading font-semibold text-[26px] sm:text-[32px] lg:text-[40px] text-headline mb-4 sm:mb-5">{item.title}</h3>}
                    {item.description && <p class="font-body text-[16px] sm:text-[18px] leading-[30px] sm:leading-[34px] lg:leading-[38px] text-body-color">{item.description}</p>}
                  </div>
                  <div class="relative flex-shrink-0 w-full max-w-[460px] h-[220px] sm:h-[280px] lg:h-[360px] mx-auto lg:mx-0">
                    <div class={`absolute border-[2.5px] border-primary rounded-[18px] w-[90%] h-[86%] sm:w-[420px] sm:h-[330px] top-3 sm:top-5 ${isEven ? 'right-0' : 'left-0'} z-[1]`}></div>
                    <div class={`absolute bottom-0 ${isEven ? 'left-0' : 'right-0'} z-[2] w-[90%] h-[86%] sm:w-[420px] sm:h-[330px] rounded-[18px] overflow-hidden flex items-center justify-center`}
                      style="background: linear-gradient(135deg, #fce4ec 0%, #f8bbd0 50%, #f48fb1 100%);"
                    >
                      {item.fotoUrl
                        ? <img src={item.fotoUrl} alt={item.title ?? ''} class="w-full h-full object-cover" />
                        : <span class="text-[64px]">🌸</span>
                      }
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )}

      <!-- SECTION 5: IDENTIDAD Y VALORES -->
      {identity && (
        <section
          class="py-14 sm:py-20 px-[6%] sm:px-[8%] text-center bg-white"
          data-nodehive-entity-type="paragraph"
          data-nodehive-entity-bundle="_component_about_identity"
          data-nodehive-entity-id={identity.paragraphId ?? null}
          data-nodehive-entity-internal-id={identity.paragraphInternalId ?? null}
          data-nodehive-parent_id={parentId ?? null}
        >
          <p class="font-body font-semibold text-[13px] sm:text-[16px] lg:text-[18px] text-primary tracking-[2px] uppercase mb-2.5" data-nodehive-field="field_subtitle_primary">
            {identitySubtitle}
          </p>
          <h2 class="font-heading font-semibold text-[32px] sm:text-[44px] lg:text-[52px] text-headline mb-8 sm:mb-12" data-nodehive-field="field_title">
            {identityTitle}
          </h2>

          {(() => {
            const tags = identity.tags;
            const rows: typeof tags[] = [];
            let i = 0;
            let rowSize = 3;
            while (i < tags.length) {
              rows.push(tags.slice(i, i + rowSize));
              i += rowSize;
              rowSize = rowSize === 3 ? 4 : 3;
            }
            return rows.map((row, rowIdx) => (
              <div class="flex flex-wrap justify-center gap-3 sm:gap-4 mb-3 sm:mb-4 px-2" data-nodehive-field={rowIdx === 0 ? 'field_identities' : undefined}>
                {row.map((tag, tagIdx) => {
                  const globalIdx = rows.slice(0, rowIdx).reduce((acc, r) => acc + r.length, 0) + tagIdx;
                  return (
                    <span class={`font-body text-[14px] sm:text-[16px] lg:text-[18px] font-medium px-4 sm:px-6 lg:px-7 py-2.5 sm:py-3.5 rounded-full ${globalIdx % 2 === 0 ? 'bg-blush text-headline' : 'bg-sage-light text-headline'}`}>
                      {tag.label}
                    </span>
                  );
                })}
              </div>
            ));
          })()}
        </section>
      )}

    </main>
  </div>
</HomeLayout>

<style>
.about-hero {
  font-family: var(--font-heading);
}
</style>
