---
import HomeLayout from '@/layouts/HomeLayout.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Footer from '@/components/ui/Footer.astro';
import { useTranslations, getLangFromUrl, getPrefix } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang  = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;
const t      = useTranslations(lang);
const prefix = getPrefix(lang);

const historiaText = lang === 'en'
  ? 'Maggy Flowers was born from a passion that became purpose: creating magic with flowers. With over 15 years of experience, Maggy has worked with both natural and artificial flowers, designing arrangements to gift, decorate homes and transform events. She studied event and wedding planning at Miami Dade College, specializing in design for memorable moments. What excites her most is creating one-of-a-kind arrangements with what she has at hand, because for her, designing flowers is pure magic. Over time, her mission evolved: not only to create, but also to teach. Today, Maggy Flowers is a floral studio and academy that inspires entrepreneurial women to monetize their floral talent through digital courses, online classes and in-person workshops. Her community is active, supportive and full of good vibes, with a practical, traditional and innovative approach at the same time.'
  : 'Maggy Flowers nació de una pasión que se convirtió en propósito: crear magia con flores. Con más de 15 años de experiencia, Maggy ha trabajado tanto con flores naturales como artificiales, diseñando arreglos para regalar, decorar hogares y transformar eventos. Estudió planificación de eventos y bodas en Miami Dade College, especializándose en diseño para momentos memorables. Lo que más la emociona es crear arreglos irrepetibles con lo que tiene a la mano, porque para ella, diseñar flores es pura magia. Con el tiempo, su misión evolucionó: no solo crear, sino también enseñar. Hoy, Maggy Flowers es un estudio floral y academia que inspira a mujeres emprendedoras a monetizar su talento floral a través de cursos digitales, clases online y talleres presenciales. Su comunidad es activa, solidaria y llena de buenas vibras, con un enfoque práctico, tradicional e innovador a la vez.';

const tags = lang === 'en'
  ? [
      { label: 'Creativity',        type: 'pink' },
      { label: 'Excellence',        type: 'green' },
      { label: 'Tradition & Innovation', type: 'pink' },
      { label: 'Magic in every design', type: 'green' },
      { label: 'Empathy',           type: 'pink' },
      { label: 'Community & Support', type: 'pink' },
      { label: 'Commitment',        type: 'green' },
      { label: 'Education with purpose', type: 'pink' },
      { label: 'Inspiration',       type: 'green' },
    ]
  : [
      { label: 'Creatividad',                 type: 'pink' },
      { label: 'Excelencia',                 type: 'green' },
      { label: 'Tradición con innovación',    type: 'pink' },
      { label: 'Magia en cada diseño',        type: 'green' },
      { label: 'Empatía',                    type: 'pink' },
      { label: 'Comunidad y apoyo',           type: 'pink' },
      { label: 'Compromiso',                 type: 'green' },
      { label: 'Educación con propósito',     type: 'pink' },
      { label: 'Inspiración',                type: 'green' },
    ];
---

<HomeLayout title={lang === 'en' ? 'About Us' : 'Sobre Nosotros'}>
  <div class="min-h-screen flex flex-col">
    <main class="flex-1">

      <!-- SECTION 1: HERO -->
      <section class="about-hero relative w-full h-[340px] flex items-center justify-center flex-col text-center overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[#f2a4a4] via-[#e8889a] to-[#d4778a]">
          <div class="absolute inset-0" style="background-image: radial-gradient(ellipse 120px 100px at 20% 80%, rgba(235,71,99,0.35) 0%, transparent 70%), radial-gradient(ellipse 180px 160px at 50% 70%, rgba(220,60,90,0.25) 0%, transparent 70%), radial-gradient(ellipse 100px 90px at 80% 85%, rgba(235,71,99,0.30) 0%, transparent 70%), radial-gradient(ellipse 200px 200px at 50% 50%, rgba(255,150,150,0.2) 0%, transparent 60%);"></div>
        </div>
        <div class="absolute inset-0" style="background: rgba(180,80,95,0.38);"></div>
        <div class="relative z-10 text-center">
          <h1 class="font-heading font-semibold text-[72px] text-white leading-[1.1] tracking-[-1px]">
            {lang === 'en' ? 'About Us' : 'Sobre Nosotros'}
          </h1>
          <p class="font-body font-medium text-[22px] text-white mt-3 tracking-wide">
            {lang === 'en' ? 'Floral design with magic, soul and purpose' : 'Diseño floral con magia, alma y propósito'}
          </p>
        </div>
      </section>

      <!-- SECTION 2: HISTORIA -->
      <section class="bg-white py-0">
        <div class="max-w-[1300px] mx-auto px-[8%] py-[90px] flex items-start gap-20">
          <div class="relative flex-shrink-0" style="width:450px; height:700px;">
            <div class="absolute border-[2.5px] border-primary rounded-[20px] w-[390px] h-[545px] top-6 right-[-24px] z-[1]"></div>
            <div class="absolute rounded-[20px] w-[390px] h-[575px] bottom-0 left-[-20px] z-[2] overflow-hidden flex items-end justify-center" style="background: linear-gradient(160deg, #f8c5c5 0%, #f2a0a0 40%, #e88888 100%);">
              <span class="text-[120px] absolute bottom-5 opacity-60">🌸</span>
            </div>
          </div>
          <div class="flex-1 pt-3">
            <p class="font-body font-semibold text-[18px] text-primary tracking-[1.5px] uppercase mb-2.5">Maggy Flowers</p>
            <h2 class="font-heading font-semibold text-[52px] text-headline leading-[1.1] mb-7">{lang === 'en' ? 'Our Story' : 'Nuestra historia'}</h2>
            <p class="font-body text-[18px] leading-[38px] text-body-color">{historiaText}</p>
          </div>
        </div>
      </section>

      <!-- SECTION 3: LOGROS -->
      <section class="py-[70px] px-[8%] text-center">
        <h2 class="font-heading font-semibold text-[52px] text-headline mb-12">{lang === 'en' ? 'Our Achievements' : 'Nuestros logros'}</h2>
        <div class="flex justify-center gap-8 flex-wrap">

          <div class="flex flex-col items-center gap-5 min-w-[280px] max-w-[340px]">
            <div class="bg-white rounded-2xl shadow-[6px_6px_20px_rgba(0,0,0,0.08)] px-12 py-9 w-full flex items-center justify-center min-h-[110px]">
              <div class="font-body font-semibold text-[17px] text-[#555] flex items-center gap-2">
                <span class="text-[22px]">📦</span>
                <div>
                  <div class="text-[14px] font-bold text-[#232f3e]">amazon</div>
                  <div class="text-[11px] text-[#555]">influencers</div>
                </div>
              </div>
            </div>
            <p class="text-[16px] font-semibold text-primary leading-[1.4] text-center">{lang === 'en' ? 'Amazon Influencer' : 'Amazon Influencer'}<br>{lang === 'en' ? 'approved' : 'aprobada'}</p>
          </div>

          <div class="flex flex-col items-center gap-5 min-w-[280px] max-w-[340px]">
            <div class="bg-white rounded-2xl shadow-[6px_6px_20px_rgba(0,0,0,0.08)] px-12 py-9 w-full flex items-center justify-center min-h-[110px]">
              <div class="font-body font-semibold text-[19px] text-[#555] flex items-center gap-2">
                <div class="w-[30px] h-[30px] bg-[#FF543E] rounded-full flex items-center justify-center text-white text-[16px] font-bold">🔥</div>
                <span>hotmart</span>
              </div>
            </div>
            <p class="text-[16px] font-semibold text-primary leading-[1.4] text-center">{lang === 'en' ? 'Floral design courses' : 'Cursos de diseño floral'}<br>Hotmart</p>
          </div>

          <div class="flex flex-col items-center gap-5 min-w-[280px] max-w-[340px]">
            <div class="bg-white rounded-2xl shadow-[6px_6px_20px_rgba(0,0,0,0.08)] px-12 py-9 w-full flex items-center justify-center min-h-[110px]">
              <div class="font-body font-bold text-[15px] text-[#555] tracking-[1px] border border-[#bbb] rounded-md px-3.5 py-1.5 flex items-center gap-2">
                <span>👑</span>
                <span>COMUNIDAD VIP</span>
              </div>
            </div>
            <p class="text-[16px] font-semibold text-primary leading-[1.4] text-center">{lang === 'en' ? 'Active VIP community of' : 'Comunidad VIP activa de'}<br>{lang === 'en' ? 'entrepreneurial women' : 'alumnas emprendedoras'}</p>
          </div>

        </div>
      </section>

      <!-- SECTION 4: CERTIFICACIONES -->
      <section class="bg-sage px-[8%] py-11 flex items-center gap-0">
        <h2 class="font-heading font-semibold text-[42px] text-white whitespace-nowrap">{lang === 'en' ? 'Certifications' : 'Certificaciones'}</h2>
        <div class="w-[2px] h-20 bg-white/50 mx-12 flex-shrink-0"></div>
        <div class="flex items-center gap-5 mr-12 flex-shrink-0">
          <div class="flex flex-col items-center gap-1">
            <div class="w-[52px] h-[42px] bg-white" style="clip-path: polygon(0 0, 55% 0, 100% 50%, 55% 100%, 0 100%, 45% 50%);"></div>
            <p class="font-body text-[11px] font-semibold text-white text-center tracking-wide">Miami Dade<br>College</p>
          </div>
        </div>
        <p class="font-body text-[22px] font-normal text-white leading-[1.5]">{lang === 'en' ? 'Event & wedding planning' : 'Formación en planificación de eventos y'}<br>{lang === 'en' ? 'training – Miami Dade College' : 'bodas – Miami Dade College'}</p>
      </section>

      <!-- SECTION 5: MISIÓN / VISIÓN -->
      <section class="bg-white py-0">
        <div class="max-w-[1300px] mx-auto px-[8%] py-[90px] flex flex-col gap-[70px]">

          <div class="flex items-center gap-[70px]">
            <div class="flex-1">
              <h2 class="font-heading font-semibold text-[52px] text-headline mb-6">Misión</h2>
              <p class="font-body text-[20px] leading-[38px] text-body-color">
                {lang === 'en'
                  ? 'Inspire and accompany entrepreneurial women to discover their floral talent, transform it into art and convert it into a sustainable business through practical, creative education based on real experience.'
                  : 'Inspirar y acompañar a mujeres emprendedoras a descubrir su talento floral, transformarlo en arte y convertirlo en un negocio sostenible mediante educación práctica, creativa y basada en la experiencia real.'}
              </p>
            </div>
            <div class="relative flex-shrink-0" style="width:460px; height:360px;">
              <div class="absolute border-[2.5px] border-primary rounded-[18px] w-[420px] h-[330px] top-5 right-0 z-[1]"></div>
              <div class="absolute bottom-0 left-0 z-[2] w-[420px] h-[330px] rounded-[18px] overflow-hidden flex items-center justify-center" style="background: linear-gradient(135deg, #fce4ec 0%, #f8bbd0 50%, #f48fb1 100%);">
                <span class="text-[64px]">🌷</span>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-[70px] flex-row-reverse">
            <div class="flex-1 text-right">
              <h2 class="font-heading font-semibold text-[52px] text-headline mb-6">Visión</h2>
              <p class="font-body text-[20px] leading-[38px] text-body-color">
                {lang === 'en'
                  ? 'To be a global reference brand in artificial and natural floral design, recognized for its creativity, high-value teaching, digital products and floral designs that emotionally connect with every person.'
                  : 'Ser una marca global referente en diseño floral artificial y natural, reconocida por su creatividad, enseñanza de alto valor, productos digitales y diseños florales que conectan emocionalmente con cada persona.'}
              </p>
            </div>
            <div class="relative flex-shrink-0" style="width:460px; height:360px;">
              <div class="absolute border-[2.5px] border-primary rounded-[18px] w-[420px] h-[330px] top-5 left-0 z-[1]"></div>
              <div class="absolute bottom-0 right-0 z-[2] w-[420px] h-[330px] rounded-[18px] overflow-hidden flex items-center justify-center" style="background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 50%, #a5d6a7 100%);">
                <span class="text-[64px]">🌹</span>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- SECTION 6: IDENTIDAD Y VALORES -->
      <section class="py-20 px-[8%] text-center bg-white">
        <p class="font-body font-semibold text-[18px] text-primary tracking-[2px] uppercase mb-2.5">{lang === 'en' ? 'Our DNA' : 'Nuestro ADN'}</p>
        <h2 class="font-heading font-semibold text-[52px] text-headline mb-12">{lang === 'en' ? 'Identity & Values' : 'Identidad y Valores'}</h2>
        <div class="flex flex-col items-center gap-[18px]">
          <div class="flex justify-center gap-4 flex-wrap">
            {tags.map(tag => (
              <span class={`font-body text-[18px] font-medium px-7 py-3.5 rounded-full whitespace-nowrap ${tag.type === 'pink' ? 'bg-blush text-headline' : 'bg-sage-light text-headline'}`}>
                {tag.label}
              </span>
            ))}
          </div>
        </div>
      </section>

    </main>
  </div>
</HomeLayout>

<style>
.about-hero {
  font-family: var(--font-heading);
}
</style>
