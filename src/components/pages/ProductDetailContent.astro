---
// Renderizado compartido para [id].astro y en/[id].astro.
// Los redirects (producto no encontrado) quedan en los archivos de página.
import HomeLayout from '@/layouts/HomeLayout.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import ProductDetail, { type ProductDetailData } from '@/components/shop/ProductDetail';
import ProductCard, { type ProductCardData } from '@/components/shop/ProductCard';
import { useTranslations } from '@/i18n/utils';
import { ui } from '@/i18n/ui';
import type { Lang } from '@/i18n/ui';

interface Props {
  lang:             Lang;
  productTitle:     string;
  productData:      Omit<ProductDetailData, 'badge'> & { badge: null };
  relatedProducts:  ProductCardData[];
}

const { lang, productTitle, productData, relatedProducts } = Astro.props;
const t      = useTranslations(lang);
const prefix = lang === 'en' ? '/en' : '';

// Computar badge en capa de presentación
const badge = productData.tipo
  ? ((ui[lang] as Record<string, string>)[`shop.filters.type.${productData.tipo}`] ?? productData.tipo)
  : null;
const fullProductData: ProductDetailData = { ...productData, badge };
---

<HomeLayout title={productTitle}>
  <div class="flex flex-col min-h-screen">
    <main class="main-container">
      <Breadcrumb crumbs={[
        { label: t('nav.home'),    href: prefix || '/' },
        { label: t('shop.title'), href: `${prefix}/shop` },
        { label: productTitle },
      ]} />

      <div class="mt-8">
        <ProductDetail product={fullProductData} lang={lang} client:load />
      </div>

      <hr class="section-divider" />

      {relatedProducts.length > 0 && (
        <section>
          <div class="flex items-center justify-between mb-8">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold text-headline tracking-tight">
              {t('product.related.title')}
            </h2>
            <a
              href={`${prefix}/shop`}
              class="group flex items-center gap-1 font-body text-sm font-bold text-primary no-underline hover:underline"
            >
              {t('product.related.see_all')}
              <span class="material-symbols-outlined text-base transition-transform group-hover:translate-x-1">
                arrow_forward
              </span>
            </a>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 lg:gap-6">
            {relatedProducts.map(p => (
              <ProductCard
                product={p}
                lang={lang}
                href={`${prefix}/${p.id}`}
                client:visible
              />
            ))}
          </div>
        </section>
      )}
    </main>
  </div>
</HomeLayout>