---
/**
 * NodeHiveConnector.astro
 *
 * Puente de comunicación entre el frontend Astro y el Visual Editor de NodeHive.
 * Solo emite un <script> — no produce HTML visible.
 *
 * Responsabilidades:
 *  1. Exponer window.__NODEHIVE_EDITOR__ con la API que necesitan los componentes
 *  2. Cuando corre dentro del iframe del editor:
 *     a) Notificar al editor que la página está lista
 *     b) Resaltar campos editables (data-nodehive-field)
 *     c) Enviar info del campo al hacer clic → el editor abre el panel de edición
 *     d) Escuchar reload/navigate del editor
 */
---

<script is:inline>
(function initNodeHiveConnector() {
  'use strict';

  /* ── 1. API global siempre disponible ─────────────────────────────────── */
  window.__NODEHIVE_EDITOR__ = window.__NODEHIVE_EDITOR__ || {};

  /**
   * Cambia el idioma navegando a la ruta equivalente.
   * Usado por HeaderClient.tsx al hacer clic en ES | EN.
   */
  window.__NODEHIVE_EDITOR__.setLang = function (lang) {
    var current = window.location.pathname;
    // Reemplazar prefijo de idioma /es/... o /en/... → /lang/...
    var next = current.replace(/^\/(es|en)(\/|$)/, '/' + lang + '$2');
    if (next === current) next = '/' + lang;
    window.location.href = next;
  };

  /* ── 2. Detectar si estamos dentro del editor (iframe) ───────────────── */
  var isInIframe = window.self !== window.top;
  var editorToken = null;

  try {
    editorToken = sessionStorage.getItem('nodehive-editor-token');
  } catch (_) {}

  if (!isInIframe) return; // Nada más que hacer en navegación normal

  document.documentElement.classList.add('nh-editor');

  /* ── 3. Variables del editor ─────────────────────────────────────────── */
  var parentOrigin = '*';

  /* ── 4. Inyectar estilos de resaltado (selectores de atributo → sin hidratación) ── */
  var style = document.createElement('style');
  style.textContent = [
    '[data-nodehive-field] {',
    '  outline: 2px dashed rgba(235,71,99,0.55);',
    '  outline-offset: 2px;',
    '  cursor: pointer;',
    '  transition: outline-color 0.15s;',
    '}',
    '[data-nodehive-field]:hover {',
    '  outline-color: rgba(235,71,99,1);',
    '  background: rgba(235,71,99,0.04);',
    '}',
    '[data-nodehive-field].--nh-active {',
    '  outline: 2px solid rgba(235,71,99,1);',
    '  background: rgba(235,71,99,0.07);',
    '}',
  ].join('\n');
  document.head.appendChild(style);

  /* ── 5. Enviar mensaje al editor padre ───────────────────────────────── */
  function sendToEditor(data) {
    console.log('[NH] sending:', JSON.stringify(data));
    try {
      window.parent.postMessage(data, parentOrigin);
    } catch (_) {}
  }

  /* ── 6. Notificar que la página está lista ───────────────────────────── */
  function notifyReady() {
    var msg = {
      type: 'frontend:ready',
      url: window.location.href,
      lang: window.__NODEHIVE_LANG__ || document.documentElement.lang || 'es',
      token: editorToken,
    };
    console.log('[NH] frontend:ready token:', editorToken, '→', JSON.stringify(msg));
    sendToEditor(msg);
  }

  /* ── 7. Registrar campos editables (delegación en document → sobrevive a React re-renders) ── */
  var _fieldsSetup = false;
  function setupEditableFields() {
    if (_fieldsSetup) return;
    _fieldsSetup = true;
    document.addEventListener('click', function (e) {
      var el = e.target.closest('[data-nodehive-field]');
      if (!el) return;

      e.preventDefault();
      e.stopPropagation();

      document.querySelectorAll('.--nh-active').forEach(function (a) {
        a.classList.remove('--nh-active');
      });
      el.classList.add('--nh-active');

      var entityEl = el.closest('[data-nodehive-type],[data-nodehive-entity-id],[data-nodehive-entity-type]');
      if (!entityEl) return;

      var entityType = entityEl.dataset.nodehiveType || entityEl.dataset.nodehiveEntityType || '';
      var entityUuid = entityEl.dataset.nodehiveUuid || entityEl.dataset.nodehiveEntityId || '';
      var entityInternalId = entityEl.dataset.nodehiveId || entityEl.dataset.nodehiveEntityInternalId || '';
      var entityParentId = entityEl.dataset.nodehiveParent_id || entityEl.dataset.nodehiveParentId || '';

      // Usar el idioma del pathname actual (del editor), NO el del atributo del párrafo
      var pathLang = window.location.pathname.split('/')[1];
      var langcode = (['es','en'].includes(pathLang)) ? pathLang : (window.__NODEHIVE_LANG__ || document.documentElement.lang || 'es');

      var fieldName = el.dataset.nodehiveField || '';

      if (fieldName) {
        sendToEditor({
          type:     'field',
          field:    fieldName,
          id:       entityInternalId || entityUuid || '',
          pathname: window.location.pathname,
          lang:     langcode,
        });
      }

      if (entityType === 'paragraph') {
        console.log('[NH DEBUG paragraph click]', {
          entityType,
          entityUuid,
          entityInternalId,
          entityParentId,
          langcode,
          element: entityEl?.outerHTML?.slice(0, 200)
        });
        sendToEditor({
          type:      'paragraph',
          uuid:      entityUuid || '',
          id:        entityInternalId || entityUuid || '',
          parent_id: entityParentId || '',
          pathname:  window.location.pathname,
          langcode:  langcode,
        });
      }
    }, true);
  }

  /* ── 8. Escuchar mensajes del editor ─────────────────────────────────── */
  window.addEventListener('message', function (event) {
    console.log('[NH] message received:', event.origin, JSON.stringify(event.data));

    var data = event.data;
    if (!data) return;

    // Mensaje legacy simple (string)
    if (data === 'reloadFrame') {
      window.location.reload();
      return;
    }

    if (typeof data !== 'object') return;

    // Capturar el origen real del editor la primera vez
    if (event.origin && event.origin !== 'null') {
      parentOrigin = event.origin;
    }

    switch (data.type) {
      case 'nodehive-login':
        if (data.token) {
          editorToken = data.token;
          try {
            sessionStorage.setItem('nodehive-editor-token', data.token);
          } catch (_) {}
          notifyReady();
        }
        break;

      case 'editor:init':
      case 'editor:ready':
        notifyReady();
        break;

      case 'reload':
      case 'reloadFrame':
        window.location.reload();
        break;

      case 'navigate':
        if (data.url) window.location.href = data.url;
        break;

      case 'setLang':
        if (data.lang) window.__NODEHIVE_EDITOR__.setLang(data.lang);
        break;
    }
  });

  /* ── 9. Inicializar cuando el DOM esté listo ────────────────────────── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () {
      setupEditableFields();
      notifyReady();
      setTimeout(notifyReady, 500);
      setTimeout(notifyReady, 1500);
      setTimeout(notifyReady, 3000);
    });
  } else {
    setupEditableFields();
    notifyReady();
    setTimeout(notifyReady, 500);
    setTimeout(notifyReady, 1500);
    setTimeout(notifyReady, 3000);
  }
})();
</script>