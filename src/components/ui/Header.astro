---
import HeaderClient from '@/components/ui/HeaderClient';
import { nodehiveFetch } from '@/services/nodehive/nodehive.client';
import { getSession } from '@/services/session.service';
import { getLangFromUrl, getPrefix } from '@/i18n/utils';
import { getHeaderLogoData } from '@/services/nodehive/nodehive.header';
import type { Lang } from '@/i18n/ui';

const session     = await getSession(Astro.cookies);
const isLoggedIn  = !!session;
const currentPath = Astro.url.pathname;
const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as 'es' | 'en';

interface MenuLink {
  title: string;
  url:   string;
}

interface MenuResponse {
  links?: MenuLink[];
}

let navLinks: { label: string; href: string }[] = [];
try {
  const res = await nodehiveFetch<MenuResponse>('/jsonapi/menu_items/main', {
    lang,
    cacheTtl: 30_000,
  });
  if (res.status === 200 && Array.isArray(res.data?.links)) {
    const prefix = getPrefix(lang);
    navLinks = res.data.links
      .map(link => {
        let href = link.url || '';
        if (href.startsWith('/')) href = `${prefix}${href}`;
        return { label: link.title || '', href };
      })
      .filter(link => {
        const p = link.href;
        return !(p === prefix || p === `${prefix}/`);
      });
  }
} catch (_) {}

const headerLogo = await getHeaderLogoData(lang);
---

<HeaderClient
  isLoggedIn={isLoggedIn}
  currentPath={currentPath}
  lang={lang}
  navLinks={navLinks}
  headerLogoData={headerLogo}
  client:load
/>