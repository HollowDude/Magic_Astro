---
interface Tab {
  label: string;
  href: string;
}

interface Props {
  tabs: Tab[];
  active: string;
}

const { tabs, active } = Astro.props;
---

<nav class="auth-tabs" role="tablist">
  {tabs.map((tab) => (
    <a
      href={tab.href}
      role="tab"
      aria-selected={tab.href === active}
      class:list={['auth-tab', { 'auth-tab-active': tab.href === active }]}
    >
      {tab.label}
    </a>
  ))}
</nav>