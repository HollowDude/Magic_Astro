---
// src/components/home/ServicesSection.astro
import ServicesCarousel from '@/components/home/ServicesCarousel';
import { getServicesParagraphData } from '@/services/nodehive/nodehive.paragraphs';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;
const data = await getServicesParagraphData(lang);
const { parentId = null } = Astro.props;

const serviciosNormalizados = data?.servicios.map((s) => ({
  title: s.titulo,
  description: s.descripcion,
  image: s.imagen,
})) ?? [];
---

<div 
  class="relative"
  data-nodehive-entity-type="paragraph"
  data-nodehive-entity-bundle="_component_home_services"
  data-nodehive-entity-id={data?.paragraphId}
  data-nodehive-entity-internal-id={data?.paragraphInternalId ?? null}
  data-nodehive-parent_id={parentId ?? null}
>
  <button
    type="button"
    class="nh-only absolute top-4 right-4 z-10 inline-flex items-center gap-2 rounded-full border border-primary/25 bg-white/90 px-3.5 py-1.5 text-xs font-semibold text-primary shadow-sm hover:bg-white"
    data-nodehive-field="field_title"
  >
    <span class="material-symbols-outlined text-[14px]">edit</span>
    Editar seccion
  </button>
  <ServicesCarousel
    titulo={data?.titulo}
    subTitulo={data?.subTitulo}
    eslogan={null}
    services={serviciosNormalizados}
    client:load
  />
</div>