---
// src/components/home/ServicesSection.astro
import ServicesCarousel from '@/components/home/ServicesCarousel';
import { getServicesParagraphData } from '@/services/nodehive/nodehive.paragraphs';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;
const data = await getServicesParagraphData(lang);

const serviciosNormalizados = data?.servicios.map((s) => ({
  title: s.titulo,
  description: s.descripcion,
  image: s.imagen,
})) ?? [];
---

<div 
  data-nodehive-entity-type="paragraph"
  data-nodehive-entity-bundle="_component_home_services"
  data-nodehive-entity-id={data?.blockId}
>
  <ServicesCarousel
    titulo={data?.titulo}
    subTitulo={data?.subTitulo}
    eslogan={null}
    services={serviciosNormalizados}
    client:load
  />
</div>