---
// src/components/home/HeroSection.astro
import HeroCarousel from '@/components/home/HeroCarousel';
import { getHomepageHeroData } from '@/services/nodehive/nodehive.paragraphs';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;
const hero = await getHomepageHeroData(lang);
---

<HeroCarousel
  title={hero?.title}
  subtitle={hero?.subtitle}
  description={hero?.description}
  slides={hero?.slides}
  ctaButtons={hero?.ctaButtons}
  lang={lang}
  client:load
/>