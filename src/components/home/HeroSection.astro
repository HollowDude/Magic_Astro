---
// src/components/home/HeroSection.astro
import HeroCarousel from '@/components/home/HeroCarousel';
import { getHomepageHeroData } from '@/services/nodehive/nodehive.paragraphs';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;
const hero = await getHomepageHeroData(lang);
---

<!-- Contenedor con atributos de NodeHive para Visual Editor -->
<section 
  data-nodehive-entity-type="node"
  data-nodehive-entity-bundle="content_page"
  data-nodehive-entity-id={hero?.pageId}
  data-nodehive-field="field_components"
>
  <HeroCarousel
    title={hero?.title}
    subtitle={hero?.subtitle}
    description={hero?.description}
    slides={hero?.slides}
    ctaButtons={hero?.ctaButtons}
    componentId={hero?.componentId}
    lang={lang}
    client:load
  />
</section>