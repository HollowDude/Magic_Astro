---
/* src/components/home/FeaturedProducts.astro [cite: 1] */
import { getProducts } from '../../services/drupal/drupal.commerce';

// Definimos la base de la URL para las imágenes
const DRUPAL_BASE_URL = 'http://localhost:8080';

// Obtenemos los productos del tipo 'flores' de forma asíncrona [cite: 2]
const products = await getProducts('flores');
---

<section class="fp-section">
  <div class="fp-container">

    <div class="fp-heading">
      <h2 class="fp-title">Productos destacados</h2>
      <span class="fp-line" aria-hidden="true"></span>
    </div>

    <div class="fp-grid">
      {products.map((product) => {
        // Extraemos la variación principal y el precio formateado
        const defaultVariation = product.variations?.[0];
        const price = defaultVariation?.price?.formatted || 'Consultar precio';
        
        // Construimos la URL de la imagen. 
        // Nota: Asegúrate de incluir 'field_image' en tus 'includes' de la API.
        const imageUrl = product.field_image?.uri?.url 
          ? `${DRUPAL_BASE_URL}${product.field_image.uri.url}`
          : '/placeholder-flower.jpg';

        return (
          <article class="fp-card">
            <div class="fp-img-wrap">
              <div
                class="fp-img"
                style={`background-image: url('${imageUrl}')`} [cite: 3]
                role="img"
                aria-label={product.title}
              />
            </div>

            <div class="fp-body">
              <h3 class="fp-name">{product.title}</h3>
              <div class="fp-footer">
                <span class="fp-price">{price}</span> [cite: 4]
                <button class="fp-btn">Comprar</button>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .fp-section {
    width: 100%;
    padding: 4rem 1rem 5rem; [cite: 5]
    background: var(--bg);
  }
  @media (min-width: 640px)  { .fp-section { padding-inline: 1.5rem; [cite: 6] } }
  @media (min-width: 1024px) { .fp-section { padding-inline: 2rem; [cite: 7] } }

  .fp-container {
    max-width: 80rem;
    margin: 0 auto; [cite: 8]
  }

  .fp-heading {
    display: flex;
    align-items: center;
    gap: 1.25rem; [cite: 9]
    margin-bottom: 2.75rem;
  }

  .fp-title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--headline); [cite: 10]
    letter-spacing: -0.02em;
    white-space: nowrap;
    margin: 0;
    line-height: 1.1;
  }

  .fp-line {
    flex: 1;
    height: 2px;
    background: var(--primary); [cite: 11]
    border-radius: 9999px;
    min-width: 2rem;
    margin-top: 0.25rem;
  }

  .fp-grid {
    display: grid;
    grid-template-columns: 1fr; [cite: 12]
    gap: 1.25rem;
  }
  @media (min-width: 540px)  { .fp-grid { grid-template-columns: repeat(2, 1fr); [cite: 13] } }
  @media (min-width: 1024px) { .fp-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; [cite: 14] } }

  .fp-card {
    background: var(--blush);
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column; [cite: 15]
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    cursor: pointer; [cite: 16]
  }
  .fp-card:hover {
    box-shadow: 0 12px 36px color-mix(in srgb, var(--headline) 15%, transparent);
    transform: translateY(-4px); [cite: 17]
  }
  .fp-card:hover .fp-btn {
    background: var(--primary); [cite: 18]
  }

  .fp-img-wrap {
    width: 100%;
    aspect-ratio: 1;
    padding: 0.75rem 0.75rem 0; [cite: 19]
  }
  .fp-img {
    width: 100%;
    height: 100%;
    border-radius: 0.625rem;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s ease; [cite: 20]
  }
  .fp-card:hover .fp-img {
    transform: scale(1.03); [cite: 21]
  }

  .fp-body {
    padding: 0.875rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem; [cite: 22]
    flex: 1;
  }

  .fp-name {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--headline); [cite: 23]
    margin: 0;
    line-height: 1.3;
  }

  .fp-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto; [cite: 24]
    padding-top: 0.25rem;
  }

  .fp-price {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--primary); [cite: 25]
  }

  .fp-btn {
    font-family: var(--font-body);
    font-size: 0.875rem; [cite: 26]
    font-weight: 600;
    color: #fff;
    background: var(--muted);
    border: none;
    border-radius: 0.5rem;
    padding: 0.5rem 1.125rem;
    cursor: pointer;
    transition: background 0.2s ease; [cite: 27]
    letter-spacing: 0.01em;
  }
</style>