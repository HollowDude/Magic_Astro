<section class="fp-section">
  <div class="fp-container">

    <!-- Título con línea decorativa -->
    <div class="fp-heading">
      <h2 class="fp-title">Productos destacados</h2>
      <span class="fp-line" aria-hidden="true"></span>
    </div>

    <!-- Grid de cards -->
    <div class="fp-grid">
      {products.map((product) => (
        <article class="fp-card">
          <div class="fp-img-wrap">
            <div
              class="fp-img"
              style={`background-image: url('${product.image}')`}
              role="img"
              aria-label={product.name}
            />
          </div>

          <div class="fp-body">
            <h3 class="fp-name">{product.name}</h3>
            <div class="fp-footer">
              <span class="fp-price">{product.price}</span>
              <button class="fp-btn">Comprar</button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section wrapper ── */
  .fp-section {
    width: 100%;
    padding: 4rem 1rem 5rem;
    background: #ffffff;
  }
  @media (min-width: 640px)  { .fp-section { padding-inline: 1.5rem; } }
  @media (min-width: 1024px) { .fp-section { padding-inline: 2rem; } }

  .fp-container {
    max-width: 80rem;
    margin: 0 auto;
  }

  /* ── Heading + decorative line ── */
  .fp-heading {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2.75rem;
  }

  .fp-title {
    font-family: 'Oddval Text', Georgia, serif;
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: #6d5157;
    letter-spacing: -0.02em;
    white-space: nowrap;
    margin: 0;
    line-height: 1.1;
  }

  .fp-line {
    flex: 1;
    height: 2px;
    background: #eb4763;
    border-radius: 9999px;
    min-width: 2rem;
    /* sit at roughly title mid-height */
    margin-top: 0.25rem;
  }

  /* ── Grid ── */
  .fp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 540px)  { .fp-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .fp-grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; } }

  /* ── Card ── */
  .fp-card {
    background: #fdeff1;
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.25s ease, transform 0.25s ease;
    cursor: pointer;
  }

  .fp-card:hover {
    box-shadow: 0 12px 36px rgba(109, 81, 87, 0.15);
    transform: translateY(-4px);
  }

  /* Hover cambia el botón a rosa */
  .fp-card:hover .fp-btn {
    background: #eb4763;
  }

  /* ── Image ── */
  .fp-img-wrap {
    width: 100%;
    aspect-ratio: 1;
    padding: 0.75rem 0.75rem 0;
  }

  .fp-img {
    width: 100%;
    height: 100%;
    border-radius: 0.625rem;
    background-size: cover;
    background-position: center;
    transition: transform 0.4s ease;
  }

  .fp-card:hover .fp-img {
    transform: scale(1.03);
  }

  /* ── Body ── */
  .fp-body {
    padding: 0.875rem 1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex: 1;
  }

  .fp-name {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #6d5157;
    margin: 0;
    line-height: 1.3;
  }

  .fp-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.25rem;
  }

  .fp-price {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 1.0625rem;
    font-weight: 700;
    color: #eb4763;
  }

  .fp-btn {
    font-family: 'Be Vietnam Pro', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: #ffffff;
    background: #ad808a;
    border: none;
    border-radius: 0.5rem;
    padding: 0.5rem 1.125rem;
    cursor: pointer;
    transition: background 0.2s ease;
    letter-spacing: 0.01em;
  }

  /* hover is handled via .fp-card:hover .fp-btn above */
</style>