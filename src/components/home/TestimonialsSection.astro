---
// src/components/home/TestimonialsSection.astro
import { getComentariosData } from '@/services/nodehive/nodehive.blocks';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;
const data = await getComentariosData(lang);

const fallbacks = {
  es: {
    titulo:      'Lo que dicen nuestros clientes',
    descripcion: 'Sus palabras son nuestra mejor inspiración.',
    comentarios: [
      { nombre: 'Sofía Ramírez',   rol: 'Novia feliz',            comentario: 'Los arreglos para mi boda superaron todas mis expectativas. Maggy capturó exactamente la esencia que queríamos transmitir. ¡Simplemente mágico!' },
      { nombre: 'Camila Torres',   rol: 'Alumna de la Academia',  comentario: 'El curso online de diseño floral es increíble. Aprendí técnicas que nunca imaginé y ahora puedo hacer mis propios arreglos en casa. ¡Muy recomendado!' },
      { nombre: 'Alejandro M.',    rol: 'Cliente frecuente',      comentario: 'Compré un ramo para el aniversario de mis padres y quedaron fascinados. La frescura y la combinación de colores fueron perfectas. Gracias Maggy.' },
    ],
  },
  en: {
    titulo:      'What our customers say',
    descripcion: 'Their words are our greatest inspiration.',
    comentarios: [
      { nombre: 'Sophia R.',   rol: 'Happy bride',         comentario: 'The arrangements for my wedding exceeded all my expectations. Maggy captured exactly the essence we wanted to convey. Simply magical!' },
      { nombre: 'Camila T.',   rol: 'Academy student',     comentario: 'The online floral design course is incredible. I learned techniques I never imagined and can now make my own arrangements at home. Highly recommended!' },
      { nombre: 'Alex M.',     rol: 'Frequent customer',   comentario: 'I bought a bouquet for my parents\' anniversary and they were thrilled. The freshness and color combination were perfect. Thank you Maggy.' },
    ],
  },
} as const;

const f = fallbacks[lang];
const titulo      = data?.titulo      ?? f.titulo;
const descripcion = data?.descripcion ?? f.descripcion;
const comentarios = data?.comentarios?.length ? data.comentarios : f.comentarios;
---

<section class="bg-sage py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-5 mb-12">
      <div>
        <h2 class="font-heading text-[clamp(1.75rem,3vw,2.5rem)] font-semibold tracking-tight text-white m-0">
          {titulo}
        </h2>
        <p class="mt-1.5 text-white/80 text-[0.9375rem] font-body">
          {descripcion}
        </p>
      </div>

      <div class="flex gap-2 shrink-0">
        <button 
          class="flex items-center justify-center w-11 h-11 rounded-full bg-white border-none cursor-pointer shadow-md transition-all duration-150 hover:shadow-lg hover:scale-105" 
          aria-label={lang === 'en' ? 'Previous' : 'Anterior'}
        >
          <svg width="16" height="18" viewBox="0 0 16 18" fill="none">
            <polygon points="13,3 13,15 3,9" fill="var(--color-muted)" stroke="var(--color-muted)" stroke-width="4" stroke-linejoin="round" stroke-linecap="round" />
          </svg>
        </button>
        <button 
          class="flex items-center justify-center w-11 h-11 rounded-full bg-white border-none cursor-pointer shadow-md transition-all duration-150 hover:shadow-lg hover:scale-105" 
          aria-label={lang === 'en' ? 'Next' : 'Siguiente'}
        >
          <svg width="16" height="18" viewBox="0 0 16 18" fill="none">
            <polygon points="3,3 3,15 13,9" fill="var(--color-muted)" stroke="var(--color-muted)" stroke-width="4" stroke-linejoin="round" stroke-linecap="round" />
          </svg>
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {comentarios.map((t) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm flex flex-col gap-5">
          <div class="flex gap-0.5" aria-label={lang === 'en' ? '5 stars' : '5 estrellas'}>
            {Array.from({ length: 5 }).map(() => (
              <span 
                class="material-symbols-outlined text-[1.25rem] leading-none" 
                style="color: #f59e0b; font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24"
              >
                star
              </span>
            ))}
          </div>
          
          <p class="text-body-color font-body text-[0.9375rem] leading-relaxed flex-1 m-0 whitespace-pre-line">
            "{t.comentario}"
          </p>
          
          <div class="flex flex-col items-end gap-0.5">
            <h4 class="font-body font-bold text-[0.9375rem] text-headline m-0 italic">
              {t.nombre}
            </h4>
            {t.rol && (
              <span class="font-body text-[0.8125rem] text-body-color">
                {t.rol}
              </span>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>