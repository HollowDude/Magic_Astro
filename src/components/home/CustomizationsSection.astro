---
// src/components/home/CustomizationsSection.astro
---

<section class="custom-section">
  <div class="custom-container">

    <!-- Imagen con efecto de marco + desbordamiento -->
    <div class="custom-img-outer">
      <div class="custom-frame"></div>
      <div class="custom-img-wrap">
        <div
          class="custom-img"
          style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDxs5NlWSf1_sZqYDP3MuvYSmKhli00fhQbpnpt7Sw1ROJhZ32ColhwrVhmOojwXVfr_S9aYkX9Q4IqwrPEmHNj8ThynAA_3HjaJW06mOUgvW_1C5h8T49djElHDEFM3BPC6WZ-4-wj_JWSY1dDUPX9oPGjZexXpMyabJLeo3d8Y3Y50YOLQ8ZNJUkAWVNYT8gfFrFD1wCcdGw4lBixS7VivWxBMSkoVBZQ9iX_ABacSbIFLgee1zQ-sA5whi4Dm9J28DVr53lQgAo')"
        />
      </div>
    </div>

    <!-- Texto -->
    <div class="custom-text">
      <h2 class="custom-title">
        Personalizaciones<br />&amp; Eventos
      </h2>
      <p class="custom-desc">
        Hacemos realidad tus sueños florales. Diseñamos arreglos únicos adaptados a tus gustos y
        necesidades, ideales para bodas, celebraciones, eventos corporativos o regalos especiales.
        Cuéntanos tu idea y nosotros pondremos la magia.
      </p>
      <a href="/contact" class="custom-cta">Contáctenos</a>
    </div>

  </div>
</section>

<style>
  .custom-section {
    background: var(--blush);
    padding: 5rem 1rem;
  }
  @media (min-width: 640px)  { .custom-section { padding-inline: 1.5rem; } }
  @media (min-width: 1024px) { .custom-section { padding-inline: 2rem; } }

  .custom-container {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .custom-container {
      flex-direction: row;
      align-items: center;
      gap: 5rem;
    }
  }

  /* ── Contenedor del conjunto marco + imagen ── */
  .custom-img-outer {
    position: relative;
    flex-shrink: 0;
    width: 100%;
    /* Espacio extra abajo e izquierda para que la imagen pueda desbordarse */
    padding-bottom: 1.75rem;
    padding-left: 1rem;
  }
  @media (min-width: 1024px) {
    .custom-img-outer { width: 46%; }
  }

  /* Marco decorativo — borde redondeado rosa, desplazado arriba-derecha */
  .custom-frame {
    position: absolute;
    /* se desplaza arriba y a la derecha respecto al origen del outer */
    top: 0;
    left: 2rem;         /* desplazado a la derecha del borde izquierdo */
    right: 0;
    bottom: 4rem;      /* no llega al fondo (ahí desborda la imagen) */
    border: 2px solid var(--primary);
    border-radius: 1rem;
    pointer-events: none;
  }

  /* Imagen — desplazada abajo-izquierda respecto al marco */
  .custom-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 1rem;
    background: #f3f4f6;
    box-shadow: 0 8px 32px rgba(0 0 0 / 0.13);
    /* desplazamiento: abajo y a la izquierda del marco */
    margin-top: 2.00rem;
    margin-right: 2.00rem;  /* crea el hueco a la derecha donde se ve el marco */
    margin-bottom: 0;
  }

  .custom-img {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
  }

  /* ── Texto ── */
  .custom-text {
    width: 100%;
  }
  @media (min-width: 1024px) { .custom-text { width: 54%; } }

  .custom-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--headline);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .custom-desc {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--body-color);
    margin-bottom: 2rem;
  }

  .custom-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 3rem;
    min-width: 10rem;
    padding: 0 2rem;
    border-radius: 9999px;
    background: var(--primary);
    color: #fff;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, background 0.2s;
  }
  .custom-cta:hover {
    transform: scale(1.05);
    background: var(--primary-dark);
  }
</style>