---
// src/components/home/CustomizationsSection.astro
import { getPersonalizationData } from '@/services/drupal/drupal.blocks';
import { getLangFromUrl } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const DRUPAL_BASE_URL = import.meta.env.DRUPAL_BASE_URL as string;

const lang = (Astro.currentLocale ?? getLangFromUrl(Astro.url)) as Lang;
const data = await getPersonalizationData(DRUPAL_BASE_URL, lang);

const descripcionFallback = lang === 'en'
  ? "We bring your floral dreams to life. We design unique arrangements tailored to your tastes and needs, ideal for weddings, celebrations, corporate events, or special gifts."
  : 'Hacemos realidad tus sueños florales. Diseñamos arreglos únicos adaptados a tus gustos y necesidades, ideales para bodas, celebraciones o regalos especiales.';

const ctaLabel = lang === 'en' ? 'Contact Us'  : 'Contáctenos';
const ctaHref  = lang === 'en' ? '/en/contact' : '/contact';

const titulo      = data?.titulo      ?? (lang === 'en' ? 'Custom Designs' : 'Diseños a Medida');
const descripcion = data?.descripcion ?? descripcionFallback;
const fotoUrl     = data?.fotoUrl     ?? 'https://via.placeholder.com/800x600';
---

<section class="bg-blush py-20 md:py-32 overflow-hidden">
  <div class="max-w-[1200px] mx-auto px-6 flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
    
    <div class="relative shrink-0 w-full lg:w-[46%] pb-7 pl-4">
      <div class="absolute top-0 left-8 right-0 bottom-16 border-2 border-primary rounded-2xl pointer-events-none" />
      <div class="relative aspect-4/3 overflow-hidden rounded-2xl bg-gray-200 shadow-2xl mt-8 mr-8">
        <div 
          class="w-full h-full bg-cover bg-center"
          style={{ backgroundImage: `url(${fotoUrl})` }}
        />
      </div>
    </div>

    <div class="w-full lg:w-[54%] text-center lg:text-left">
      <h2 class="font-body text-[clamp(2rem,4vw,3rem)] font-black leading-[1.15] tracking-[-0.02em] text-headline mb-6">
        {titulo}
      </h2>
      <p class="font-body text-lg leading-relaxed text-body-color mb-10 max-w-[600px] mx-auto lg:mx-0">
        {descripcion}
      </p>
      <a 
        href={ctaHref}
        class="inline-flex items-center justify-center h-14 px-10 rounded-full bg-primary text-white text-base font-bold no-underline transition-all duration-200 hover:scale-105 hover:bg-primary-dark shadow-[0_10px_20px_color-mix(in_srgb,var(--color-primary)_30%,transparent)]"
      >
        {ctaLabel}
      </a>
    </div>

  </div>
</section>