          {'★'.repeat(5)}
        </div>
        <span>Estudiantes felices</span>
      </div>
    </div>
  </div>
</aside>

<style>
  .hero-panel {
    display: none;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .hero-panel {
      display: flex;
      width: 50%;
      align-items: center;
      justify-content: center;
    }
  }

  /* ── Background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--primary) 25%, transparent);
    mix-blend-mode: overlay;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(33, 17, 20, 0.55) 0%, transparent 60%);
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 10;
    padding: 3rem;
    color: white;
    max-width: 28rem;
  }

  .hero-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 2.5rem;
    font-weight: 700;
    font-size: 1.125rem;
    letter-spacing: -0.01em;
  }

  .logo-icon {
    font-size: 1.75rem;
  }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    text-shadow: 0 2px 12px rgba(0 0 0 / 0.3);
  }

  .hero-desc {
    font-size: 1.0625rem;
    line-height: 1.65;
    opacity: 0.88;
    text-shadow: 0 1px 4px rgba(0 0 0 / 0.25);
    margin-bottom: 2rem;
  }

  /* ── Social proof ── */
  .social-proof {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .avatars {
    display: flex;
    align-items: center;
  }

  .avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 2px solid white;
    object-fit: cover;
    margin-left: -0.625rem;
  }

  .avatar:first-child {
    margin-left: 0;
  }

  .avatar-count {
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255 255 255 / 0.2);
    backdrop-filter: blur(4px);
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .proof-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .stars {
    color: #fde047;
    font-size: 0.8125rem;
    letter-spacing: 0.05em;
  }

  .proof-text span {
    font-size: 0.8125rem;
    font-weight: 600;
    opacity: 0.9;
  }
</style>
