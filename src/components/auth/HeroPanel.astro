---
interface Props {
  title?: string | null;
  description?: string | null;
  fotoUrl?: string | null;
  paragraphId?: string | null;
  paragraphInternalId?: number | null;
  parentId?: string | number | null;
  bundle?: string | null;
}

const FALLBACK_FOTO = 'https://lh3.googleusercontent.com/aida-public/AB6AXuCjSe0_Qz6_SN8vKCVuFwTExt2M0w1wiF_Yg7YsXCnG2_JNpq1VS4Q6oD3DcwFJ_CyxqK9QhQUQBqmcstzzYb-pdGI-knucx9G7SPBnTRDMf_5VvwCEUcpWWtEwPYIAUJaSxCpWVhwO1hj3Cb6O1OTJSkCbRJrF2uIeNVDncz7So3lB6yWvVQ_M33YPUJfStR-0PRDtfDdz4gtxWubxJVjoSa14Sn3KGcrkt18cq00BYpI1Z4lSOj_LCWU_ehKK1IaYcyt54NVnsaA';

const {
  title = 'Descubre el arte floral',
  description = 'Únete a nuestra comunidad de apasionados por las flores. Aprende técnicas exclusivas y crea arreglos unflorecientes.',
  fotoUrl = null,
  paragraphId = null,
  paragraphInternalId = null,
  parentId = null,
  bundle = null,
} = Astro.props;

const bgImage = fotoUrl ?? FALLBACK_FOTO;
---

<aside
  class="hero-panel"
  data-nodehive-entity-type={bundle ? 'paragraph' : undefined}
  data-nodehive-entity-bundle={bundle ?? undefined}
  data-nodehive-entity-id={paragraphId ?? undefined}
  data-nodehive-entity-internal-id={paragraphInternalId ?? undefined}
  data-nodehive-parent_id={parentId ?? undefined}
>
  <div class="hero-bg">
    <img
      src={bgImage}
      alt={title ?? 'Imagen decorativa'}
      class="hero-img"
      loading="eager"
    />
    <div class="hero-overlay"></div>
    <div class="hero-gradient"></div>
  </div>

  <div class="hero-content">
    <h1
      class="hero-title"
      data-nodehive-field={paragraphId ? 'field_title' : undefined}
    >
      {title}
    </h1>
    {description && (
      <p
        class="hero-desc"
        data-nodehive-field={paragraphId ? 'field_description_long' : undefined}
      >
        {description}
      </p>
    )}
  </div>
</aside>

<style>
  .hero-panel {
    display: none;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .hero-panel {
      display: flex;
      width: 50%;
      align-items: center;
      justify-content: center;
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.9;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--primary) 30%, transparent);
    mix-blend-mode: overlay;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(33, 17, 20, 0.70) 0%, rgba(33, 17, 20, 0.35) 60%, rgba(33, 17, 20, 0.15) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 10;
    padding: 3rem;
    color: white;
    max-width: 28rem;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
    text-shadow: 0 2px 8px rgba(0 0 0 / 0.6), 0 4px 20px rgba(0 0 0 / 0.4);
  }

  .hero-desc {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.65;
    opacity: 0.95;
    text-shadow: 0 2px 8px rgba(0 0 0 / 0.6), 0 4px 20px rgba(0 0 0 / 0.4);
  }
</style>
