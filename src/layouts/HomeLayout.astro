---
// src/layouts/BaseLayout.astro
import Header from '@/components/ui/Header.astro';
import Footer from '@/components/ui/Footer.astro';
import '@/styles/global.css';

interface Props {
  title?: string;
}

interface Props { title?: string; lang?: string }
const { title = 'Inicio', lang = 'es' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Maggy Flowers</title>
    <script define:vars={{ nodehiveBaseUrl: import.meta.env.NODEHIVE_BASE_URL, nodehiveLang: lang }}>
      window.__NODEHIVE_BASE_URL__ = nodehiveBaseUrl;
      window.__NODEHIVE_LANG__ = nodehiveLang;
    </script>
  </head>
  <body class="bg-background-light text-text-main font-body antialiased">
    <Header />
    <slot />
    <Footer lang={lang} />
    <script is:inline>
      (function() {
        var isInIframe = window.self !== window.top;

        window.addEventListener('message', async function(event) {
          if (event.data === 'reloadFrame') {
            try {
              await fetch('/api/nodehive/revalidate?path=' + encodeURIComponent(window.location.pathname));
            } catch(e) {}
            window.location.reload();
          }
        });
      })();
    </script>
  </body>
</html>