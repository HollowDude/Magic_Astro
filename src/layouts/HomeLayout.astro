---
// src/layouts/BaseLayout.astro
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Inicio' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Maggy Flowers</title>

    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem('mf-lang');
          if (pref !== 'en') return;

          var path = window.location.pathname;
          var isEnglishPath = path === '/en' || path.startsWith('/en/');

          if (!isEnglishPath) {
            var enPath = path === '/' ? '/en' : '/en' + path;
            window.location.replace(enPath);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-background-light text-text-main font-body antialiased">
    <slot />
  </body>
</html>